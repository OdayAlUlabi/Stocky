{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "environmentName": { "value": "${AZURE_ENV_NAME}" },
    "location": { "value": "${AZURE_LOCATION}" },
    "googleClientId": { "value": "${GOOGLE_CLIENT_ID}" },
    "sqlEntraAdminObjectId": { "value": "${SQL_ENTRA_ADMIN_OBJECT_ID}" },
    "sqlEntraAdminLogin": { "value": "${SQL_ENTRA_ADMIN_LOGIN}" },
    "githubRepo": { "value": "${GITHUB_REPO=OdayAlUlabi/Stocky}" },
    "vnetAddressSpace": { "value": "${SPOKE_VNET_ADDRESS_SPACE=10.40.0.0/20}" },
    "hubVnetResourceId": { "value": "${HUB_VNET_RESOURCE_ID=}" },
    "hubFirewallPrivateIp": { "value": "${HUB_FIREWALL_PRIVATE_IP=}" },
    "centralDnsZonesRgId": { "value": "${CENTRAL_DNS_ZONES_RG_ID=}" },
    "githubOwner": { "value": "${GITHUB_OWNER=OdayAlUlabi}" },
    "githubRunnerRepo": { "value": "${GITHUB_RUNNER_REPO=Stocky}" },
    "githubAppId": { "value": "${GITHUB_APP_ID=}" },
    "githubInstallationId": { "value": "${GITHUB_INSTALLATION_ID=}" },
    "githubAppPrivateKeySecretName": { "value": "${GITHUB_APP_KEY_SECRET=github-app-private-key}" },
    "githubRunnerLabels": { "value": "${GITHUB_RUNNER_LABELS=stocky}" },
    "tlsCertSecretUri": { "value": "${TLS_CERT_SECRET_URI=}" }
  }
}
