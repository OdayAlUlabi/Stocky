@model List<TransactionDto>
@{
    var pid = (Guid)ViewBag.PortfolioId;
    var portfolio = ViewBag.Portfolio as PortfolioDto;
    ViewData["Title"] = (portfolio?.Name ?? "Portfolio") + " · Transactions";
    ViewBag.PickerPathTemplate = "/Portfolios/{0}/Transactions";
}

<div class="page-header">
    <h2>
        <i class="bi bi-arrow-left-right"></i> Transactions
        @await Html.PartialAsync("_PortfolioPicker")
    </h2>
    <div class="actions">
        <a href="/Portfolios/Detail/@pid" class="btn btn-ghost btn-sm"><i class="bi bi-arrow-left"></i> Portfolio</a>
        <a href="/Portfolios/@pid/Cash" class="btn btn-ghost btn-sm"><i class="bi bi-cash-coin"></i> Cash</a>
        <a href="/Portfolios/@pid/Transactions/Timeline" class="btn btn-ghost btn-sm"><i class="bi bi-diagram-3"></i> Timeline</a>
        <a href="/Portfolios/@pid/Transactions/Import" class="btn btn-ghost"><i class="bi bi-upload"></i> Import CSV</a>
        <a href="/Portfolios/@pid/Transactions/Create" class="btn btn-primary"><i class="bi bi-plus-lg"></i> New transaction</a>
    </div>
</div>

@if (TempData["Status"] is string status)
{
    <div class="flash success">@status</div>
}

<article>
    <table>
        <thead>
            <tr>
                <th>Date</th>
                <th>Type</th>
                <th>Symbol</th>
                <th style="text-align:right;">Qty</th>
                <th style="text-align:right;">Price</th>
                <th style="text-align:right;" class="d-none-mobile">Fee</th>
                <th style="text-align:right;" class="d-none-mobile">Cash effect</th>
                <th style="text-align:right;" class="d-none-mobile">Cash balance</th>
                <th style="text-align:right;" class="d-none-mobile">Current Price</th>
                <th style="text-align:right;" class="d-none-mobile">Market Value</th>
                <th class="d-none-mobile">Notes</th>
                <th style="text-align:right;">Actions</th>
            </tr>
        </thead>
        <tbody>
            @{
                decimal totalMv = 0m;
                decimal netSignedMv = 0m;
                decimal netCash = 0m;
                decimal investedCapital = 0m;
                string? footerCcy = null;
                static decimal CashEffect(string type, decimal qty, decimal price, decimal fee)
                {
                    var gross = qty * price;
                    return type?.ToLowerInvariant() switch
                    {
                        "buy" => -(gross + fee),
                        "sell" => gross - fee,
                        "deposit" or "dividend" or "interest" or "transfer" => gross,
                        "withdrawal" or "withdraw" or "fee" => -gross,
                        _ => 0m
                    };
                }
                static decimal CapitalEffect(string type, decimal qty, decimal price)
                {
                    // Invested capital = net cash the user contributed to the
                    // account (deposits + external transfers in − withdrawals).
                    // Dividends/Interest/trade P&L are NOT contributions.
                    var gross = qty * price;
                    return type?.ToLowerInvariant() switch
                    {
                        "deposit" or "transfer" => gross,
                        "withdrawal" or "withdraw" => -gross,
                        _ => 0m
                    };
                }
                // Compute the running cash balance in chronological order so the
                // value shown on each row reflects the post-transaction balance.
                // The table itself is rendered newest-first, so we look up the
                // pre-computed balance by transaction id.
                var balanceById = new Dictionary<Guid, decimal>(Model.Count);
                {
                    decimal running = 0m;
                    foreach (var t in Model.OrderBy(x => x.ExecutedAt))
                    {
                        running += CashEffect(t.Type, t.Quantity, t.Price, t.Fee);
                        balanceById[t.Id] = running;
                    }
                }
            }
            @foreach (var t in Model)
            {
                var isBuy = string.Equals(t.Type, "Buy", StringComparison.OrdinalIgnoreCase);
                var isSell = string.Equals(t.Type, "Sell", StringComparison.OrdinalIgnoreCase);
                var pillCls = isBuy ? "badge-up" : isSell ? "badge-down" : "pill";
                if (t.MarketValue.HasValue)
                {
                    totalMv += t.MarketValue.Value;
                    if (isBuy) netSignedMv += t.MarketValue.Value;
                    else if (isSell) netSignedMv -= t.MarketValue.Value;
                    footerCcy ??= t.Currency;
                }
                var cashEffect = CashEffect(t.Type, t.Quantity, t.Price, t.Fee);
                netCash += cashEffect;
                investedCapital += CapitalEffect(t.Type, t.Quantity, t.Price);
                footerCcy ??= t.Currency;
                var runningBalance = balanceById[t.Id];
                <tr>
                    <td class="text-muted">@t.ExecutedAt.ToString("yyyy-MM-dd HH:mm")</td>
                    <td><span class="@pillCls">@t.Type</span></td>
                    <td><strong>@t.Symbol</strong></td>
                    <td style="text-align:right;">@t.Quantity.Num(4)</td>
                    <td style="text-align:right;">@t.Price.Money(t.Currency)</td>
                    <td style="text-align:right;" class="d-none-mobile text-muted">@t.Fee.Money(t.Currency)</td>
                    <td style="text-align:right;" class="d-none-mobile @cashEffect.SignClass()">@cashEffect.Money(t.Currency)</td>
                    <td style="text-align:right;" class="d-none-mobile"><strong>@runningBalance.Money(t.Currency)</strong></td>
                    <td style="text-align:right;" class="d-none-mobile">@t.LatestPrice.Money(t.Currency)</td>
                    <td style="text-align:right;" class="d-none-mobile">@t.MarketValue.Money(t.Currency)</td>
                    <td class="d-none-mobile text-muted">@t.Notes</td>
                    <td style="text-align:right;">
                        <a href="/Portfolios/@pid/Transactions/Edit/@t.Id" class="btn btn-ghost btn-sm" title="Edit"><i class="bi bi-pencil"></i></a>
                        <form method="post" action="/Portfolios/@pid/Transactions/Delete/@t.Id" style="display:inline;" onsubmit="return confirm('Delete this transaction?');">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-danger btn-sm" title="Delete"><i class="bi bi-trash"></i></button>
                        </form>
                    </td>
                </tr>
            }
            @if (Model.Count == 0)
            {
                <tr>
                    <td colspan="12" style="text-align:center;padding:2rem;">
                        <div class="text-muted" style="margin-bottom:.75rem;"><i class="bi bi-inbox" style="font-size:2rem;"></i></div>
                        <p class="text-muted">No transactions yet.</p>
                        <a href="/Portfolios/@pid/Transactions/Create" class="btn btn-primary"><i class="bi bi-plus-lg"></i> Add first transaction</a>
                    </td>
                </tr>
            }
        </tbody>
        @if (Model.Count > 0 && footerCcy is not null)
        {
            <tfoot>
                <tr>
                    <td colspan="6" style="text-align:right;" class="text-muted">Invested capital (Deposits + Transfers − Withdrawals)</td>
                    <td colspan="2" style="text-align:right;"><strong>@investedCapital.Money(footerCcy)</strong></td>
                    <td colspan="4"></td>
                </tr>
                <tr>
                    <td colspan="6" style="text-align:right;" class="text-muted">Net cash effect (all transactions)</td>
                    <td colspan="2" style="text-align:right;" class="@netCash.SignClass()"><strong>@netCash.Money(footerCcy)</strong></td>
                    <td colspan="4"></td>
                </tr>
                <tr>
                    <td colspan="9" style="text-align:right;" class="text-muted">Net market value (Buys − Sells)</td>
                    <td style="text-align:right;"><strong>@netSignedMv.Money(footerCcy)</strong></td>
                    <td colspan="2"></td>
                </tr>
            </tfoot>
        }
    </table>
</article>
