@model List<EconomicEventDto>
@{
    ViewData["Title"] = "Economic calendar";
    var from = ViewBag.From as DateOnly?;
    var to = ViewBag.To as DateOnly?;
}
<div class="page-header"><h2><i class="bi bi-calendar3"></i> Economic calendar</h2></div>
<form method="get" action="/Calendar/Economic" style="display:flex;gap:.5rem;align-items:end;">
    <label>From <input type="date" name="from" value="@(from?.ToString("yyyy-MM-dd"))" /></label>
    <label>To <input type="date" name="to" value="@(to?.ToString("yyyy-MM-dd"))" /></label>
    <button type="submit">Filter</button>
</form>
<table>
    <thead><tr><th>Date</th><th>Time</th><th>Country</th><th>Indicator</th><th>Importance</th><th style="text-align:right;">Actual</th><th style="text-align:right;">Forecast</th><th style="text-align:right;">Previous</th><th>Unit</th></tr></thead>
    <tbody>
        @foreach (var e in Model)
        {
            <tr>
                <td>@e.Date</td>
                <td>@e.Time</td>
                <td>@e.Country</td>
                <td>@e.Indicator</td>
                <td>@e.Importance</td>
                <td style="text-align:right;">@(e.Actual?.Num(2) ?? "—")</td>
                <td style="text-align:right;">@(e.Forecast?.Num(2) ?? "—")</td>
                <td style="text-align:right;">@(e.Previous?.Num(2) ?? "—")</td>
                <td>@e.Unit</td>
            </tr>
        }
        @if (Model.Count == 0) { <tr><td colspan="9"><em>No events.</em></td></tr> }
    </tbody>
</table>
