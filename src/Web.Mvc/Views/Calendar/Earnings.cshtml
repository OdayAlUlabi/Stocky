@model List<EarningsEventDto>
@{
    ViewData["Title"] = "Earnings calendar";
    var from = ViewBag.From as DateOnly?;
    var to = ViewBag.To as DateOnly?;
    var scope = ViewBag.Scope as string ?? "holdings";
}
<div class="page-header"><h2><i class="bi bi-calendar2-event"></i> Portfolio Earnings <small class="text-muted">· @scope</small></h2></div>
<div class="filter-bar">
    <form method="get" action="/Calendar/Earnings" style="display:flex;gap:.5rem;align-items:flex-end;flex-wrap:wrap;">
        <label>From <input type="date" name="from" value="@(from?.ToString("yyyy-MM-dd"))" /></label>
        <label>To <input type="date" name="to" value="@(to?.ToString("yyyy-MM-dd"))" /></label>
        <label>Scope
            <select name="scope">
                @foreach (var s in new[] { "holdings", "watchlist", "all" })
                {
                    <option value="@s" selected="@(scope == s)">@(char.ToUpper(s[0]) + s[1..])</option>
                }
            </select>
        </label>
        <button type="submit" class="btn btn-ghost"><i class="bi bi-search"></i> Filter</button>
    </form>
</div>
<article>
    <table>
        <thead>
            <tr>
                <th>Date</th>
                <th>Time</th>
                <th>Symbol</th>
                <th style="text-align:right;">EPS est</th>
                <th style="text-align:right;">EPS actual</th>
                <th style="text-align:right;">Revenue est</th>
                <th style="text-align:right;">Revenue actual</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var e in Model)
            {
                <tr>
                    <td class="text-muted">@e.Date</td>
                    <td class="text-muted">@(e.Time ?? "—")</td>
                    <td><strong>@e.Symbol</strong></td>
                    <td style="text-align:right;">@(e.EpsEstimate?.Num(2) ?? "—")</td>
                    <td style="text-align:right;">@(e.EpsActual?.Num(2) ?? "—")</td>
                    <td style="text-align:right;">@(e.RevenueEstimate?.Num(0) ?? "—")</td>
                    <td style="text-align:right;">@(e.RevenueActual?.Num(0) ?? "—")</td>
                </tr>
            }
            @if (Model.Count == 0)
            {
                <tr><td colspan="7">
                    <div class="empty-state">
                        <i class="bi bi-calendar2-event empty-icon"></i>
                        <p>No earnings in this window for <em>@scope</em>.</p>
                    </div>
                </td></tr>
            }
        </tbody>
    </table>
</article>
