@model Stocky.Web.Mvc.ViewModels.SingleStockDashboardViewModel
@{
    ViewData["Title"] = $"{Model.Symbol} Research";
    var analysis = Model.Analysis;
    var backtest = Model.Backtest;
    var wf = Model.WalkForward;
    var setup = analysis.Setup;
    var closes = Model.Bars.Select(b => (double)b.Close).ToList();
    var equity = backtest.EquityCurve.Select(p => (double)p.Equity).ToList();
    var chartWidth = 920;
    var chartHeight = 260;
    var tvSymbol = (ViewBag.TradingViewSymbol as string) ?? (Model.Symbol.Contains(':') ? Model.Symbol : $"NASDAQ:{Model.Symbol}");
    var tvInterval = (ViewBag.TradingViewInterval as string) ?? "D";
    var timeframeOptions = new[] { "5m", "15m", "30m", "1H", "4H", "1D", "1W", "1M" };

    string BuildPolyline(IReadOnlyList<double> values, int width, int height)
    {
        if (values.Count == 0) return string.Empty;
        var min = values.Min();
        var max = values.Max();
        var span = Math.Max(0.0001, max - min);
        return string.Join(" ", values.Select((value, index) =>
        {
            var x = values.Count == 1 ? width / 2.0 : (index * (width - 20.0) / (values.Count - 1)) + 10;
            var y = height - 12 - ((value - min) / span * (height - 24));
            return $"{x:F1},{y:F1}";
        }));
    }

    var pricePoints = BuildPolyline(closes, chartWidth, chartHeight);
    var equityPoints = BuildPolyline(equity, chartWidth, chartHeight);
}

<section class="page-header" style="display:flex;justify-content:space-between;gap:1rem;align-items:flex-start;flex-wrap:wrap;">
    <div>
        <h2>@Model.Symbol single-stock research</h2>
        <p class="text-muted" style="margin:0;">Research-only dashboard. No order execution. All figures are for one ticker and one regime.</p>
    </div>
    <form method="get" action="/stocks/@Model.Symbol" style="display:flex;gap:.5rem;flex-wrap:wrap;align-items:end;">
        <label>
            Symbol<br />
            <input name="symbol" value="@Model.Symbol" />
        </label>
        <label>
            Timeframe<br />
            <select name="timeframe">
                @foreach (var tf in timeframeOptions)
                {
                    if (string.Equals(Model.Timeframe, tf, StringComparison.OrdinalIgnoreCase))
                    {
                        <option value="@tf" selected>@tf</option>
                    }
                    else
                    {
                        <option value="@tf">@tf</option>
                    }
                }
            </select>
        </label>
        <label>
            History years<br />
            <input name="historyYears" type="number" min="1" max="10" value="@Model.Strategy.HistoryYears" />
        </label>
        <label>
            Take profit %<br />
            <input name="takeProfitPercent" type="number" step="0.1" value="@Model.Strategy.TakeProfitPercent" />
        </label>
        <label>
            Stop loss %<br />
            <input name="stopLossPercent" type="number" step="0.1" value="@Model.Strategy.StopLossPercent" />
        </label>
        <button class="btn btn-primary" type="submit">Run</button>
    </form>
</section>

@{
    var stateColor = setup.State switch {
        "Ready" or "Active" => "#22c55e",
        "Watching" => "#f59e0b",
        _ => "#94a3b8"
    };
    var confidencePct = (int)(setup.Confidence * 100);
    var confidenceColor = confidencePct >= 75 ? "#22c55e" : confidencePct >= 50 ? "#f59e0b" : "#ef4444";
    var winRateColor = backtest.WinRate >= 55 ? "#22c55e" : backtest.WinRate >= 45 ? "#f59e0b" : "#ef4444";
    var vwapChange = analysis.VwapDeviation;
    var priceVsVwapColor = vwapChange > 0 ? "#22c55e" : vwapChange < 0 ? "#ef4444" : "#94a3b8";
    var entryLower = setup.EntryLowerBound;
    var entryUpper = setup.EntryUpperBound;
    var suggestedEntry = entryLower.HasValue && entryUpper.HasValue
        ? Math.Round((entryLower.Value + entryUpper.Value) / 2m, 4)
        : setup.EntryPrice ?? analysis.CurrentPrice ?? 0m;
    var suggestedStop = setup.StopLossPrice ?? (suggestedEntry > 0m
        ? Math.Round(suggestedEntry * (1m - (Model.Strategy.StopLossPercent / 100m)), 4)
        : 0m);
    var riskPerShare = suggestedEntry > 0m && suggestedStop > 0m
        ? suggestedEntry - suggestedStop
        : 0m;
    var target1 = setup.TakeProfitPrice ?? (suggestedEntry > 0m
        ? Math.Round(suggestedEntry * (1m + (Model.Strategy.TakeProfitPercent / 100m)), 4)
        : 0m);
    var tdstResistance = Model.TdSequential?.TdstResistance;
    var target2 = tdstResistance.HasValue && tdstResistance.Value > target1
        ? tdstResistance.Value
        : (riskPerShare > 0m ? Math.Round(suggestedEntry + (riskPerShare * 2.5m), 4) : target1);
    var target3 = riskPerShare > 0m
        ? Math.Round(suggestedEntry + (riskPerShare * 3.5m), 4)
        : target2;
    var rr1 = riskPerShare > 0m ? Math.Round((target1 - suggestedEntry) / riskPerShare, 2) : 0m;
    var rr2 = riskPerShare > 0m ? Math.Round((target2 - suggestedEntry) / riskPerShare, 2) : 0m;
    var rr3 = riskPerShare > 0m ? Math.Round((target3 - suggestedEntry) / riskPerShare, 2) : 0m;
    var metConditions = setup.Conditions.Count(c => c.IsMet);
    var totalConditions = setup.Conditions.Count;
    var currentPrice = analysis.CurrentPrice ?? 0m;
    var taBias = setup.State == "Triggered" && setup.Confidence >= 0.60m
        ? "Constructive long bias"
        : (setup.Confidence >= 0.40m ? "Neutral-to-bullish bias" : "Weak setup - wait for confirmation");

    var latestBar = Model.Bars.LastOrDefault();
    var sessionOpen = latestBar?.Open ?? 0m;
    var sessionHigh = latestBar?.High ?? 0m;
    var sessionLow = latestBar?.Low ?? 0m;
    var openingRangeHigh = Math.Max(sessionOpen, sessionHigh);
    var openingRangeLow = Math.Min(sessionOpen, sessionLow);
    var openingRangePct = sessionOpen > 0m
        ? Math.Round(((openingRangeHigh - openingRangeLow) / sessionOpen) * 100m, 2)
        : 0m;

    var recentVolumes = Model.Bars.TakeLast(20).Select(b => (decimal)b.Volume).ToList();
    var avgVol20 = recentVolumes.Count > 0 ? recentVolumes.Average() : 0m;
    var latestVol = latestBar is not null ? (decimal)latestBar.Volume : 0m;
    var rvol20 = avgVol20 > 0m ? Math.Round(latestVol / avgVol20, 2) : 0m;

    var recentCloses = Model.Bars.TakeLast(20).Select(b => b.Close).ToList();
    var closeMean = recentCloses.Count > 0 ? recentCloses.Average() : 0m;
    var closeVariance = recentCloses.Count > 1
        ? recentCloses.Sum(c => (c - closeMean) * (c - closeMean)) / recentCloses.Count
        : 0m;
    var closeSigma = (decimal)Math.Sqrt((double)closeVariance);

    var vwapBasis = analysis.Vwap ?? currentPrice;
    var vwapUpper1 = vwapBasis + closeSigma;
    var vwapLower1 = Math.Max(0m, vwapBasis - closeSigma);
    var vwapUpper2 = vwapBasis + (closeSigma * 2m);
    var vwapLower2 = Math.Max(0m, vwapBasis - (closeSigma * 2m));

    var setupStatus = analysis.EarningsBlackoutActive
        ? "Invalidated"
        : setup.State == "Triggered"
            ? "Triggered"
            : setup.Confidence >= 0.45m ? "Watching" : "Invalidated";
    var setupStatusColor = setupStatus switch
    {
        "Triggered" => "#22c55e",
        "Watching" => "#f59e0b",
        _ => "#ef4444"
    };
    var entryZoneReady = entryLower.HasValue && entryUpper.HasValue;
    var inEntryZone = entryZoneReady && currentPrice >= entryLower!.Value && currentPrice <= entryUpper!.Value;

    var bullProbability = (int)Math.Clamp(
        Math.Round((double)(setup.Confidence * 100m)
            + (analysis.VwapDeviation.HasValue ? (analysis.VwapDeviation.Value < 0m ? 8 : -4) : 0)
            + (double)((backtest.WinRate - 50m) / 2m)),
        10,
        80);
    var bearProbability = (int)Math.Clamp(100 - bullProbability - 20, 10, 70);
    var baseProbability = 100 - bullProbability - bearProbability;

    var baseTarget = target1;
    var bullTarget = target2;
    var bearTarget = suggestedStop;
}
<div class="kpi-grid">
    <div class="kpi">
        <div class="label">Current price</div>
        <div class="value">@((analysis.CurrentPrice ?? 0m).ToString("N2"))
            @if (vwapChange.HasValue) {
                var arrow = vwapChange > 0 ? "▲" : "▼";
                <span style="font-size:.85rem;color:@priceVsVwapColor;margin-left:.25rem;">@arrow vs VWAP</span>
            }
        </div>
        <div class="delta text-muted">@analysis.AsOf?.ToLocalTime().ToString("MMM d · HH:mm")</div>
    </div>
    <div class="kpi">
        <div class="label">Setup state</div>
        <div class="value" style="display:flex;align-items:center;gap:.5rem;">
            <span style="display:inline-block;width:10px;height:10px;border-radius:50%;background:@stateColor;box-shadow:0 0 6px @stateColor;"></span>
            @setup.State
        </div>
        <div class="delta text-muted">@analysis.BarCount bars</div>
    </div>
    <div class="kpi">
        <div class="label">Confidence</div>
        <div class="value" style="color:@confidenceColor;">@setup.Confidence.ToString("P0")</div>
        <div style="margin-top:.35rem;height:4px;border-radius:4px;background:rgba(255,255,255,.1);overflow:hidden;">
            <div style="height:100%;width:@(confidencePct)%;background:@confidenceColor;border-radius:4px;transition:width .4s;"></div>
        </div>
        <div class="delta text-muted" style="margin-top:.25rem;">R:R @(setup.RiskRewardRatio?.ToString("N2") ?? "n/a")</div>
    </div>
    <div class="kpi">
        <div class="label">Backtest trades</div>
        <div class="value">@backtest.TradeCount</div>
        <div class="delta" style="color:@winRateColor;">Win rate @backtest.WinRate.ToString("N1")%</div>
    </div>
</div>

<article>
    <header>
        <span>Live setup card</span>
        <small class="text-muted">Entry zone, stop, target, and checklist</small>
    </header>
    <div class="grid-2" style="grid-template-columns:1.1fr .9fr;align-items:start;">
        <div>
            <p style="margin-top:0;">@setup.State with @setup.Conditions.Count conditions checked.</p>
            <table>
                <tbody>
                    <tr><td>Entry zone</td><td>@(setup.EntryLowerBound?.ToString("N2") ?? "n/a") - @(setup.EntryUpperBound?.ToString("N2") ?? "n/a")</td></tr>
                    <tr><td>Stop loss</td><td>@(setup.StopLossPrice?.ToString("N2") ?? "n/a")</td></tr>
                    <tr><td>Target</td><td>@(setup.TakeProfitPrice?.ToString("N2") ?? "n/a")</td></tr>
                    <tr><td>Confidence</td><td>@setup.Confidence.ToString("P0")</td></tr>
                </tbody>
            </table>
        </div>
        <div>
            <ul style="margin:0;padding-left:0;list-style:none;display:flex;flex-direction:column;gap:.4rem;">
                @foreach (var condition in setup.Conditions)
                {
                    var condColor = condition.IsMet ? "#22c55e" : "#ef4444";
                    var condBg = condition.IsMet ? "rgba(34,197,94,.08)" : "rgba(239,68,68,.08)";
                    var condIcon = condition.IsMet ? "✓" : "✗";
                    <li style="display:flex;align-items:center;gap:.5rem;padding:.35rem .6rem;border-radius:6px;background:@condBg;font-size:.875rem;">
                        <span style="color:@condColor;font-weight:700;font-size:1rem;min-width:1rem;text-align:center;">@condIcon</span>
                        <span>@condition.Label</span>
                    </li>
                }
            </ul>
            @if (analysis.Warnings.Count > 0)
            {
                <div class="alert alert-warning" style="margin-top:1rem;">
                    @foreach (var warning in analysis.Warnings)
                    {
                        <div>@warning</div>
                    }
                </div>
            }
        </div>
    </div>
</article>

<article>
    <header>
        <span>VWAP Mean Reversion</span>
        <small class="text-muted">Volume-Weighted Average Price for mean reversion signals</small>
    </header>
@{
    var dev = analysis.VwapDeviation ?? 0m;
    var devAbs = Math.Abs(dev);
    // Bar width: clamp 0-100, threshold ±5% = full bar
    var devBarWidth = (int)Math.Min(100, devAbs / 5m * 100);
    var devBarColor = dev > 2m ? "#ef4444" : dev < -2m ? "#22c55e" : dev > 0 ? "#f59e0b" : "#3b82f6";
    var devLabel = dev >= 0 ? $"+{dev:N2}%" : $"{dev:N2}%";
    var signalStrength = devAbs > 2m ? "Strong" : "Weak";
    var signalStrengthColor = devAbs > 2m ? devBarColor : "#94a3b8";
}
<div style="display:grid;grid-template-columns:1fr 1fr;gap:1.5rem;align-items:start;">
    <div>
        <table>
            <tbody>
                <tr><td>Current Price</td><td style="font-weight:600;">@((analysis.CurrentPrice ?? 0m).ToString("N2"))</td></tr>
                <tr><td>VWAP (Cumulative)</td><td style="font-weight:600;">@(analysis.Vwap?.ToString("N2") ?? "n/a")</td></tr>
                <tr>
                    <td>Deviation</td>
                    <td style="color:@devBarColor;font-weight:700;">@(analysis.VwapDeviation.HasValue ? devLabel : "n/a")</td>
                </tr>
            </tbody>
        </table>
        @if (analysis.VwapDeviation.HasValue)
        {
            <div style="margin-top:.75rem;">
                <div style="display:flex;justify-content:space-between;font-size:.75rem;color:var(--color-muted);margin-bottom:.25rem;">
                    <span>Oversold ◀</span><span>VWAP</span><span>▶ Overbought</span>
                </div>
                <div style="height:8px;border-radius:8px;background:rgba(255,255,255,.1);position:relative;overflow:visible;">
                    @* center tick *@
                    <div style="position:absolute;left:50%;top:-2px;width:2px;height:12px;background:rgba(255,255,255,.3);transform:translateX(-50%);"></div>
                    @* deviation fill *@
                    @if (dev >= 0)
                    {
                        <div style="position:absolute;left:50%;height:100%;width:@(devBarWidth/2)%;background:@devBarColor;border-radius:0 8px 8px 0;"></div>
                    }
                    else
                    {
                        <div style="position:absolute;right:50%;height:100%;width:@(devBarWidth/2)%;background:@devBarColor;border-radius:8px 0 0 8px;"></div>
                    }
                </div>
            </div>
        }
    </div>
    <div>
        @if (!string.IsNullOrEmpty(analysis.MeanReversionSignal))
        {
            <div style="padding:1rem;border-radius:10px;border:1px solid @devBarColor;background:@(devBarColor)18;">
                <div style="display:flex;align-items:center;gap:.5rem;margin-bottom:.4rem;">
                    <span style="width:8px;height:8px;border-radius:50%;background:@signalStrengthColor;display:inline-block;"></span>
                    <span style="font-weight:700;font-size:.8rem;color:@signalStrengthColor;text-transform:uppercase;letter-spacing:.05em;">@signalStrength signal</span>
                </div>
                <p style="margin:0;font-size:.9rem;">@analysis.MeanReversionSignal</p>
            </div>
        }
        else
        {
            <p class="text-muted">No VWAP data available</p>
        }
    </div>
</div>
</article>

<article class="ta-plan">
    <header>
        <span>Technical analysis plan</span>
        <small class="text-muted">Rules-based suggestion for entry and profit taking</small>
    </header>
    <div class="ta-plan-grid">
        <div>
            <div class="ta-bias">@taBias</div>
            <p class="text-muted" style="margin:.5rem 0 0;">@metConditions / @totalConditions setup conditions are currently met. Treat this as a planning aid, not financial advice.</p>
            <table style="margin-top:.75rem;">
                <tbody>
                    <tr><td>Suggested entry</td><td style="font-weight:700;">@(suggestedEntry > 0m ? suggestedEntry.ToString("N2") : "n/a")</td></tr>
                    <tr><td>Suggested stop</td><td>@(suggestedStop > 0m ? suggestedStop.ToString("N2") : "n/a")</td></tr>
                    <tr><td>Risk per share</td><td>@(riskPerShare > 0m ? riskPerShare.ToString("N2") : "n/a")</td></tr>
                </tbody>
            </table>
        </div>
        <div>
            <div class="ta-targets">
                <div class="ta-target">
                    <strong>Take profit 1</strong>
                    <span>@(target1 > 0m ? target1.ToString("N2") : "n/a")</span>
                    <small>Scale out 40% · R:R @rr1</small>
                </div>
                <div class="ta-target">
                    <strong>Take profit 2</strong>
                    <span>@(target2 > 0m ? target2.ToString("N2") : "n/a")</span>
                    <small>Scale out 40% · R:R @rr2</small>
                </div>
                <div class="ta-target">
                    <strong>Take profit 3</strong>
                    <span>@(target3 > 0m ? target3.ToString("N2") : "n/a")</span>
                    <small>Runner 20% · R:R @rr3</small>
                </div>
            </div>
        </div>
    </div>
</article>

<article class="analysis-block intraday-context">
    <header style="display:flex;justify-content:space-between;gap:.75rem;align-items:center;flex-wrap:wrap;">
        <div>
            <span>Intraday context (analysis)</span>
            <small class="text-muted" style="display:block;">Opening range, RVOL, and VWAP bands for monitoring</small>
        </div>
        <div class="refresh-controls">
            <label style="display:inline-flex;gap:.35rem;align-items:center;margin:0;">
                <input id="auto-refresh-toggle" type="checkbox" />
                Auto refresh
            </label>
            <select id="auto-refresh-interval" aria-label="Auto refresh interval">
                <option value="15">15s</option>
                <option value="30" selected>30s</option>
                <option value="60">60s</option>
                <option value="120">120s</option>
            </select>
        </div>
    </header>
    <div class="intraday-grid">
        <div class="intraday-card">
            <strong>Opening range</strong>
            <div class="intraday-main">@openingRangeHigh.ToString("N2") / @openingRangeLow.ToString("N2")</div>
            <small class="text-muted">Range width: @openingRangePct.ToString("N2")%</small>
        </div>
        <div class="intraday-card">
            <strong>RVOL (20)</strong>
            <div class="intraday-main @(rvol20 >= 1.5m ? "text-green" : rvol20 >= 1.0m ? string.Empty : "text-red")">@rvol20.ToString("N2")x</div>
            <small class="text-muted">Last vol @latestVol.ToString("N0") vs avg @avgVol20.ToString("N0")</small>
        </div>
        <div class="intraday-card">
            <strong>VWAP bands</strong>
            <div class="intraday-main">@vwapBasis.ToString("N2")</div>
            <small class="text-muted">±1σ: @vwapLower1.ToString("N2") - @vwapUpper1.ToString("N2")</small>
            <small class="text-muted" style="display:block;">±2σ: @vwapLower2.ToString("N2") - @vwapUpper2.ToString("N2")</small>
        </div>
        <div class="intraday-card">
            <strong>Session positioning</strong>
            <div class="intraday-main">@(currentPrice > vwapBasis ? "Above VWAP" : "Below VWAP")</div>
            <small class="text-muted">Price @currentPrice.ToString("N2") | Basis @vwapBasis.ToString("N2")</small>
        </div>
    </div>
</article>

<article class="analysis-block">
    <header>
        <span>Setup state machine</span>
        <small class="text-muted">Analysis-only workflow: Watching -> Triggered -> Invalidated</small>
    </header>
    <div class="state-machine-grid">
        <div class="state-card" style="border-color:@setupStatusColor;">
            <div class="state-title">
                <span class="state-dot" style="background:@setupStatusColor;"></span>
                <strong>@setupStatus</strong>
            </div>
            <p class="text-muted" style="margin:.35rem 0 0;">@taBias</p>
            <p style="margin:.5rem 0 0;font-size:.88rem;">Conditions met: @metConditions / @totalConditions</p>
        </div>
        <div class="state-card">
            <strong>Why this status</strong>
            <ul class="state-list">
                <li>Entry zone: @(entryZoneReady ? $"{entryLower:0.00} - {entryUpper:0.00}" : "Not available")</li>
                <li>Current price: @(currentPrice > 0m ? currentPrice.ToString("N2") : "n/a") (@(inEntryZone ? "inside" : "outside") zone)</li>
                <li>VWAP signal: @(string.IsNullOrWhiteSpace(analysis.MeanReversionSignal) ? "n/a" : analysis.MeanReversionSignal)</li>
                <li>Earnings blackout: @(analysis.EarningsBlackoutActive ? "Active" : "None")</li>
            </ul>
        </div>
    </div>
</article>

<article class="analysis-block">
    <header>
        <span>Scenario board</span>
        <small class="text-muted">Probability-weighted analysis paths (no order execution)</small>
    </header>
    <div class="scenario-grid">
        <div class="scenario-card scenario-base">
            <div class="scenario-head">
                <strong>Base case</strong>
                <span>@baseProbability%</span>
            </div>
            <p>Price respects the current range and mean-reverts around VWAP.</p>
            <div class="scenario-level">Reference target: @(baseTarget > 0m ? baseTarget.ToString("N2") : "n/a")</div>
        </div>
        <div class="scenario-card scenario-bull">
            <div class="scenario-head">
                <strong>Bull case</strong>
                <span>@bullProbability%</span>
            </div>
            <p>Setup confirms with momentum and pushes toward higher resistance.</p>
            <div class="scenario-level">Upside path: @(bullTarget > 0m ? bullTarget.ToString("N2") : "n/a")</div>
        </div>
        <div class="scenario-card scenario-bear">
            <div class="scenario-head">
                <strong>Bear case</strong>
                <span>@bearProbability%</span>
            </div>
            <p>Setup loses structure and re-tests invalidation support.</p>
            <div class="scenario-level">Risk level: @(bearTarget > 0m ? bearTarget.ToString("N2") : "n/a")</div>
        </div>
    </div>
</article>

<article class="analysis-block">
    <header>
        <span>Alert rules (analysis-only)</span>
        <small class="text-muted">Use as monitoring conditions; no broker integration</small>
    </header>
    <div class="alerts-grid">
        <div class="alert-rule">
            <strong>Entry-zone touch</strong>
            <p>Alert when price enters the suggested entry zone.</p>
            <span class="rule-state @(inEntryZone ? "is-on" : "is-off")">@(inEntryZone ? "Live now" : "Waiting")</span>
        </div>
        <div class="alert-rule">
            <strong>VWAP reclaim/loss</strong>
            <p>Alert when VWAP deviation crosses back toward neutral.</p>
            <span class="rule-state @(analysis.VwapDeviation.HasValue && Math.Abs(analysis.VwapDeviation.Value) <= 0.5m ? "is-on" : "is-off")">
                @(analysis.VwapDeviation.HasValue && Math.Abs(analysis.VwapDeviation.Value) <= 0.5m ? "Near trigger" : "Waiting")
            </span>
        </div>
        <div class="alert-rule">
            <strong>Structure break</strong>
            <p>Alert when price breaks TDST support/resistance context.</p>
            <span class="rule-state @(Model.TdSequential?.TdstResistance.HasValue == true && currentPrice > Model.TdSequential.TdstResistance.Value ? "is-on" : "is-off")">
                @(Model.TdSequential?.TdstResistance.HasValue == true && currentPrice > Model.TdSequential.TdstResistance.Value ? "Resistance break" : "Waiting")
            </span>
        </div>
    </div>
</article>

<article>
    <header>
        <span>TradingView chart</span>
        <small class="text-muted">Interactive chart for @tvSymbol</small>
    </header>
    <div id="tradingview-stocky-widget" style="height:460px;border:1px solid rgba(0,0,0,.08);border-radius:12px;overflow:hidden;"></div>
</article>

<article>
    <header>
        <span>Price chart</span>
        <small class="text-muted">Daily close series with simple server-rendered SVG</small>
    </header>
    <svg viewBox="0 0 @chartWidth @chartHeight" width="100%" height="@chartHeight" role="img" aria-label="price chart" style="background:rgba(0,0,0,.02);border:1px solid rgba(0,0,0,.08);border-radius:12px;">
        <polyline fill="none" stroke="currentColor" stroke-width="2.5" points="@pricePoints" />
    </svg>
</article>

<div class="grid-2">
    <article>
        <header>
            <span>Profitability panel</span>
            <small class="text-muted">After costs and slippage</small>
        </header>
        <table>
            <tbody>
                <tr><td>Verdict</td><td>@backtest.Verdict</td></tr>
                <tr><td>Final equity</td><td>@backtest.FinalEquity.ToString("N2")</td></tr>
                <tr><td>Net P&amp;L</td><td>@backtest.NetPnL.ToString("N2")</td></tr>
                <tr><td>Total return</td><td>@backtest.TotalReturnPercent.ToString("N2")%</td></tr>
                <tr><td>Profit factor</td><td>@backtest.ProfitFactor.ToString("N2")</td></tr>
                <tr><td>Expectancy / trade</td><td>@backtest.ExpectancyPerTrade.ToString("N2")</td></tr>
                <tr><td>Max drawdown</td><td>@backtest.MaxDrawdown.ToString("N2")%</td></tr>
                <tr><td>Sharpe</td><td>@backtest.Sharpe.ToString("N2")</td></tr>
            </tbody>
        </table>
        <h4>Walk-forward</h4>
        <p>@wf.Verdict</p>
        <p class="text-muted">In-sample net P&amp;L: @wf.InSample.NetPnL.ToString("N2") | Out-of-sample net P&amp;L: @wf.OutOfSample.NetPnL.ToString("N2")</p>
    </article>

    <article>
        <header>
            <span>Parameters</span>
            <small class="text-muted">Adjust and rerun</small>
        </header>
        <form method="get" action="/stocks/@Model.Symbol" style="display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:.75rem;">
            <input type="hidden" name="symbol" value="@Model.Symbol" />
            <label>Timeframe
                <select name="timeframe">
                    @foreach (var tf in timeframeOptions)
                    {
                        if (string.Equals(Model.Timeframe, tf, StringComparison.OrdinalIgnoreCase))
                        {
                            <option value="@tf" selected>@tf</option>
                        }
                        else
                        {
                            <option value="@tf">@tf</option>
                        }
                    }
                </select>
            </label>
            <label>History years<input name="historyYears" type="number" min="1" max="10" value="@Model.Strategy.HistoryYears" /></label>
            <label>Take profit %<input name="takeProfitPercent" type="number" step="0.1" value="@Model.Strategy.TakeProfitPercent" /></label>
            <label>Stop loss %<input name="stopLossPercent" type="number" step="0.1" value="@Model.Strategy.StopLossPercent" /></label>
            <label>Time stop bars<input name="timeStopBars" type="number" min="1" max="90" value="@Model.Strategy.TimeStopBars" /></label>
            <label>Initial cash<input name="initialCash" type="number" step="100" value="10000" /></label>
            <label>Max risk %<input name="maxRiskPerTradePercent" type="number" step="0.1" value="@Model.Strategy.MaxRiskPerTradePercent" /></label>
            <label>Trailing stop<input name="useTrailingStop" type="checkbox" value="true" @(Model.Strategy.UseTrailingStop ? "checked" : null) /></label>
            <label>Partial exit<input name="enablePartialExit" type="checkbox" value="true" @(Model.Strategy.EnablePartialExit ? "checked" : null) /></label>
            <label>Partial target %<input name="partialExitTargetPercent" type="number" step="0.1" value="@Model.Strategy.PartialExitTargetPercent" /></label>
            <label>Partial qty %<input name="partialExitQuantityPercent" type="number" step="0.1" value="@Model.Strategy.PartialExitQuantityPercent" /></label>
            <div style="grid-column:1 / -1;display:flex;gap:.5rem;">
                <button class="btn btn-primary" type="submit">Re-run backtest</button>
                <a class="btn btn-ghost" href="/stocks/@Model.Symbol">Reset</a>
            </div>
        </form>
    </article>
</div>

<article>
    <header>
        <span>Trade log</span>
        <small class="text-muted">Every historical signal with outcome</small>
    </header>
    <table>
        <thead>
            <tr>
                <th>Entry</th>
                <th>Exit</th>
                <th style="text-align:right;">Qty</th>
                <th style="text-align:right;">Entry</th>
                <th style="text-align:right;">Exit</th>
                <th>Reason</th>
                <th style="text-align:right;">Net P&amp;L</th>
            </tr>
        </thead>
        <tbody>
            @if (backtest.TradeLog.Count == 0)
            {
                <tr><td colspan="7" class="text-muted" style="text-align:center;padding:1rem;">No completed trades for this configuration.</td></tr>
            }
            else
            {
                foreach (var trade in backtest.TradeLog)
                {
                    <tr>
                        <td>@trade.EntryDate</td>
                        <td>@trade.ExitDate</td>
                        <td style="text-align:right;">@trade.Quantity.ToString("N0")</td>
                        <td style="text-align:right;">@trade.EntryPrice.ToString("N2")</td>
                        <td style="text-align:right;">@trade.ExitPrice.ToString("N2")</td>
                        <td>@trade.ExitReason @(trade.IsPartialExit ? "(partial)" : string.Empty)</td>
                        <td style="text-align:right;" class="@(trade.NetPnL >= 0 ? "text-green" : "text-red")">@trade.NetPnL.ToString("N2")</td>
                    </tr>
                }
            }
        </tbody>
    </table>
</article>

<article>
    <header>
        <span>Equity curve</span>
        <small class="text-muted">Net value over the backtest window</small>
    </header>
    <svg viewBox="0 0 @chartWidth @chartHeight" width="100%" height="@chartHeight" role="img" aria-label="equity curve" style="background:rgba(0,0,0,.02);border:1px solid rgba(0,0,0,.08);border-radius:12px;">
        <polyline fill="none" stroke="currentColor" stroke-width="2.5" points="@equityPoints" />
    </svg>
</article>

@* ─────────────────────────────── TD Sequential section ─────────────────────────────── *@
@if (Model.TdSequential is { } td)
{
    var tdBuy  = "#22c55e";   @* green *@
    var tdSell = "#ef4444";   @* red *@

    <div class="grid-2">
        <article>
            <header>
                <span>TD Sequential — current state</span>
                <small class="text-muted">DeMark setup + countdown counts</small>
            </header>
            <table>
                <tbody>
                    <tr>
                        <td>Buy Setup</td>
                        <td style="color:@tdBuy;font-weight:600;">
                            @(td.BuySetupCurrent > 0 ? td.BuySetupCurrent.ToString() : "–")
                            @if (td.BuySetupCurrent == 9) { <span>✔ Done</span> }
                        </td>
                    </tr>
                    <tr>
                        <td>Sell Setup</td>
                        <td style="color:@tdSell;font-weight:600;">
                            @(td.SellSetupCurrent > 0 ? td.SellSetupCurrent.ToString() : "–")
                            @if (td.SellSetupCurrent == 9) { <span>✔ Done</span> }
                        </td>
                    </tr>
                    <tr>
                        <td>Buy Countdown</td>
                        <td style="color:@tdBuy;">
                            @if (td.BuyCDActive)
                            {
                                <span>@td.BuyCountdownCurrent / 13</span>
                            }
                            else
                            {
                                <span class="text-muted">inactive</span>
                            }
                        </td>
                    </tr>
                    <tr>
                        <td>Sell Countdown</td>
                        <td style="color:@tdSell;">
                            @if (td.SellCDActive)
                            {
                                <span>@td.SellCountdownCurrent / 13</span>
                            }
                            else
                            {
                                <span class="text-muted">inactive</span>
                            }
                        </td>
                    </tr>
                    <tr><td>TDST Resistance</td><td>@(td.TdstResistance?.ToString("N2") ?? "–")</td></tr>
                    <tr><td>TDST Support</td><td>@(td.TdstSupport?.ToString("N2") ?? "–")</td></tr>
                </tbody>
            </table>
        </article>

        @if (td.VolumeProfile is { } vp)
        {
            <article>
                <header>
                    <span>Volume Profile</span>
                    <small class="text-muted">Last 250 bars · 24 bins · 70% value area</small>
                </header>
                <table>
                    <tbody>
                        <tr><td>POC</td><td style="font-weight:600;">@vp.Poc.ToString("N2")</td></tr>
                        <tr><td>Value Area High</td><td>@vp.Vah.ToString("N2")</td></tr>
                        <tr><td>Value Area Low</td><td>@vp.Val.ToString("N2")</td></tr>
                    </tbody>
                </table>
                @{
                    var maxBinVol = td.VolumeProfile!.Bins.Max(b => b.Volume);
                }
                <div style="margin-top:.75rem;display:flex;flex-direction:column-reverse;gap:1px;">
                    @foreach (var bin in vp.Bins)
                    {
                        var widthPct = maxBinVol > 0 ? (int)Math.Round(bin.Volume / maxBinVol * 100) : 0;
                        var bgColor = bin.IsPoc ? "var(--color-warning,#f59e0b)"
                                    : bin.IsValueArea ? "rgba(59,130,246,.45)"
                                    : "rgba(100,116,139,.25)";
                        <div style="display:flex;align-items:center;gap:.4rem;font-size:10px;line-height:1.2;">
                            <span style="width:4.5rem;text-align:right;color:var(--color-muted);">@bin.PriceLow.ToString("N2")</span>
                            <div style="height:9px;width:@(widthPct)%;background:@bgColor;border-radius:2px;min-width:2px;"></div>
                            @if (bin.IsPoc) { <span style="color:var(--color-warning,#f59e0b);font-weight:700;">POC</span> }
                        </div>
                    }
                </div>
            </article>
        }
    </div>
}

@section Scripts {
    <script src="https://s3.tradingview.com/tv.js"></script>
    <script>
    (function () {
        var containerId = "tradingview-stocky-widget";
        if (!window.TradingView || !document.getElementById(containerId)) {
            return;
        }

        new TradingView.widget({
            autosize: true,
            symbol: "@tvSymbol",
            interval: "@tvInterval",
            timezone: "Etc/UTC",
            theme: "light",
            style: "1",
            locale: "en",
            enable_publishing: false,
            hide_top_toolbar: false,
            hide_legend: false,
            save_image: false,
            container_id: containerId
        });
    }());

    (function () {
        var toggle = document.getElementById("auto-refresh-toggle");
        var intervalSelect = document.getElementById("auto-refresh-interval");
        if (!toggle || !intervalSelect || !window.localStorage) {
            return;
        }

        var enabledKey = "stocky.analysis.autorefresh.enabled";
        var intervalKey = "stocky.analysis.autorefresh.interval";
        var savedEnabled = window.localStorage.getItem(enabledKey) === "true";
        var savedInterval = window.localStorage.getItem(intervalKey);

        if (savedInterval) {
            intervalSelect.value = savedInterval;
        }
        toggle.checked = savedEnabled;

        var timerId = null;
        function applyRefresh() {
            if (timerId) {
                window.clearInterval(timerId);
                timerId = null;
            }

            var enabled = toggle.checked;
            var seconds = parseInt(intervalSelect.value, 10);
            if (!enabled || Number.isNaN(seconds) || seconds < 10) {
                return;
            }

            timerId = window.setInterval(function () {
                window.location.reload();
            }, seconds * 1000);
        }

        toggle.addEventListener("change", function () {
            window.localStorage.setItem(enabledKey, toggle.checked ? "true" : "false");
            applyRefresh();
        });

        intervalSelect.addEventListener("change", function () {
            window.localStorage.setItem(intervalKey, intervalSelect.value);
            applyRefresh();
        });

        applyRefresh();
    }());
    </script>
}