@model List<NewsItemDto>
@{
    ViewData["Title"] = "News";
    var sym = ViewBag.Symbols as string;
    var lim = (int)ViewBag.Limit;
}
<h2>News</h2>
<form method="get" action="/News" style="display:flex;gap:.5rem;align-items:end;">
    <label>Symbols (comma-separated) <input name="symbols" value="@sym" placeholder="AAPL,MSFT" /></label>
    <label>Limit <input name="limit" type="number" value="@lim" min="5" max="200" /></label>
    <button type="submit">Filter</button>
</form>
<table>
    <thead><tr><th>Published</th><th>Symbol</th><th>Source</th><th>Headline</th></tr></thead>
    <tbody>
        @foreach (var n in Model)
        {
            <tr>
                <td>@n.PublishedAt.ToString("yyyy-MM-dd HH:mm")</td>
                <td>@n.Symbol</td>
                <td>@n.Source</td>
                <td>@(string.IsNullOrEmpty(n.Url) ? (object)n.Headline : (object)Html.Raw($"<a href=\"{System.Net.WebUtility.HtmlEncode(n.Url)}\" target=\"_blank\" rel=\"noopener\">{System.Net.WebUtility.HtmlEncode(n.Headline)}</a>"))</td>
            </tr>
        }
        @if (Model.Count == 0) { <tr><td colspan="4"><em>No news.</em></td></tr> }
    </tbody>
</table>
