@{
    var path = (Context.Request.Path.Value ?? "/").ToLowerInvariant();
    string nav(string href, params string[] match)
    {
        var active = match.Any(m =>
            string.Equals(path, m, StringComparison.OrdinalIgnoreCase) ||
            path.StartsWith(m.TrimEnd('/') + "/", StringComparison.OrdinalIgnoreCase));
        return active ? "nav-link active" : "nav-link";
    }
    var userName = User?.Identity?.Name ?? "user";
    var initials = string.Concat((userName ?? "U")
        .Split(new[] { ' ', '.', '@', '-', '_' }, StringSplitOptions.RemoveEmptyEntries)
        .Take(2)
        .Select(p => char.ToUpper(p[0])));
    if (string.IsNullOrEmpty(initials)) initials = "U";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] · Stocky</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@@400;500;600;700&family=JetBrains+Mono:wght@@400;500&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@@1.11.3/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
<div class="app">
    <aside class="sidebar">
        <div class="brand">
            <i class="bi bi-graph-up-arrow"></i>
            <span>Stocky</span>
        </div>

        <nav>
            <div class="nav-group">
                <div class="nav-group-label">Overview</div>
                <a class="@nav("/", "/")" href="/"><i class="bi bi-speedometer2"></i>Dashboard</a>
                <a class="@nav("/Portfolios", "/portfolios")" href="/Portfolios"><i class="bi bi-briefcase"></i>Portfolios</a>
                <a class="@nav("/Transactions", "/transactions")" href="/Transactions"><i class="bi bi-arrow-left-right"></i>Transactions</a>
                <a class="@nav("/Cash", "/cash")" href="/Cash"><i class="bi bi-cash-coin"></i>Cash</a>
            </div>

            <div class="nav-group">
                <div class="nav-group-label">Analytics</div>
                <a class="@nav("/PortfolioAnalytics/Performance", "/portfolioanalytics/performance")" href="/PortfolioAnalytics/Performance"><i class="bi bi-bar-chart-line"></i>Performance</a>
                <a class="@nav("/PortfolioAnalytics/Reports", "/portfolioanalytics/reports")" href="/PortfolioAnalytics/Reports"><i class="bi bi-file-earmark-bar-graph"></i>Reports</a>
                <a class="@nav("/PortfolioAnalytics/Rebalance", "/portfolioanalytics/rebalance")" href="/PortfolioAnalytics/Rebalance"><i class="bi bi-sliders"></i>Rebalance</a>
            </div>

            <div class="nav-group">
                <div class="nav-group-label">Tools</div>
                <a class="@nav("/Tools/Momentum", "/tools/momentum")" href="/Tools/Momentum"><i class="bi bi-graph-up-arrow"></i>Momentum</a>
                <a class="@nav("/Tools/Optimizer", "/tools/optimizer")" href="/Tools/Optimizer"><i class="bi bi-bullseye"></i>Optimizer</a>
                <a class="@nav("/Tools/PositionSizing", "/tools/positionsizing")" href="/Tools/PositionSizing"><i class="bi bi-rulers"></i>Position Sizing</a>
            </div>

            <div class="nav-group">
                <div class="nav-group-label">Research</div>
                <a class="@nav("/Watchlist", "/watchlist")" href="/Watchlist"><i class="bi bi-eye"></i>Watchlist</a>
                <a class="@nav("/Screener", "/screener")" href="/Screener"><i class="bi bi-funnel"></i>Screener</a>
                <a class="@nav("/Alerts", "/alerts")" href="/Alerts"><i class="bi bi-bell"></i>Alerts</a>
                <a class="@nav("/News", "/news")" href="/News"><i class="bi bi-newspaper"></i>News</a>
                <a class="@nav("/Earnings", "/earnings")" href="/Earnings"><i class="bi bi-calendar-event"></i>Earnings</a>
                <a class="@nav("/Calendar/Earnings", "/calendar/earnings")" href="/Calendar/Earnings"><i class="bi bi-calendar2-event"></i>Earnings (mine)</a>
                <a class="@nav("/Calendar/Economic", "/calendar/economic")" href="/Calendar/Economic"><i class="bi bi-calendar3"></i>Economic</a>
            </div>

            <div class="nav-group">
                <div class="nav-group-label">Planning</div>
                <a class="@nav("/Goals", "/goals")" href="/Goals"><i class="bi bi-bullseye"></i>Goals</a>
                <a class="@nav("/Templates", "/templates")" href="/Templates"><i class="bi bi-collection"></i>Templates</a>
                <a class="@nav("/Notes", "/notes")" href="/Notes"><i class="bi bi-journal-text"></i>Notes</a>
                <a class="@nav("/ReportSchedules", "/reportschedules")" href="/ReportSchedules"><i class="bi bi-clock-history"></i>Reports</a>
                <a class="@nav("/Share", "/share")" href="/Share"><i class="bi bi-share"></i>Share</a>
            </div>

            <div class="nav-group">
                <div class="nav-group-label">Account</div>
                <a class="@nav("/Settings", "/settings")" href="/Settings"><i class="bi bi-gear"></i>Settings</a>
                <a class="@nav("/ApiKeys", "/apikeys")" href="/ApiKeys"><i class="bi bi-key"></i>API Keys</a>
                <a class="@nav("/Admin/Audit", "/admin")" href="/Admin/Audit"><i class="bi bi-shield-check"></i>Audit Log</a>
                <a class="@nav("/Admin/DataRefresh")" href="/Admin/DataRefresh"><i class="bi bi-arrow-repeat"></i>Data Refresh</a>
            </div>
        </nav>
    </aside>

    <div>
        <div class="topbar">
            <div class="crumb">
                <i class="bi bi-house-door"></i>
                <strong>@(ViewData["Title"] ?? "Stocky")</strong>
            </div>
            <div class="user">
                <span class="d-none-mobile">@userName</span>
                <div class="avatar" title="@userName">@initials</div>
            </div>
        </div>

        <main class="content">
            @if (TempData["Status"] is string status && !string.IsNullOrWhiteSpace(status))
            {
                <div class="flash success"><i class="bi bi-check-circle"></i> @status</div>
            }
            @if (TempData["Error"] is string err && !string.IsNullOrWhiteSpace(err))
            {
                <div class="flash error"><i class="bi bi-exclamation-circle"></i> @err</div>
            }
            @RenderBody()
        </main>

        <footer class="app-footer">
            <span>Stocky · server-rendered MVC</span>
        </footer>
    </div>
</div>
<partial name="_TickerAutocomplete" />
<script src="https://cdn.jsdelivr.net/npm/@@microsoft/signalr@@8.0.7/dist/browser/signalr.min.js"></script>
<script src="~/js/prices-hub.js" asp-append-version="true" defer></script>
<script src="~/js/table-sort.js" asp-append-version="true" defer></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
