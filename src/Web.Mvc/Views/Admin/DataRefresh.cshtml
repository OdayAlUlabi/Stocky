@{
    ViewData["Title"] = "Data refresh";
    var payload = TempData["RefreshPayload"] as string;
    var portfoliosJson = TempData["PortfolioValues"] as string;
    var coverageJson = TempData["Coverage"] as string;
    List<Stocky.Api.Services.PortfolioValueSnapshot> portfolios = new();
    if (!string.IsNullOrWhiteSpace(portfoliosJson))
    {
        try
        {
            portfolios = System.Text.Json.JsonSerializer.Deserialize<List<Stocky.Api.Services.PortfolioValueSnapshot>>(
                portfoliosJson,
                new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true }) ?? new();
        }
        catch { portfolios = new(); }
    }
    var coverage = ViewBag.Coverage as IReadOnlyList<Stocky.Api.Services.HistoricalCoverageRow>
        ?? new List<Stocky.Api.Services.HistoricalCoverageRow>();
    if (!string.IsNullOrWhiteSpace(coverageJson))
    {
        try
        {
            coverage = System.Text.Json.JsonSerializer.Deserialize<List<Stocky.Api.Services.HistoricalCoverageRow>>(
                coverageJson,
                new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true }) ?? coverage;
        }
        catch { /* keep ViewBag fallback */ }
    }
    var today = DateOnly.FromDateTime(DateTime.UtcNow);
}
<div class="page-header">
    <h2><i class="bi bi-arrow-repeat"></i> Data refresh</h2>
    <p class="muted">Force a one-shot data pull from the configured market data provider. Useful off-hours or right after rotating provider keys.</p>
</div>

<div class="card" style="padding:1rem;max-width:640px;">
    <form method="post" action="/Admin/DataRefresh" style="display:flex;flex-direction:column;gap:.75rem;">
        @Html.AntiForgeryToken()
        <label>
            <span style="display:block;font-weight:600;margin-bottom:.25rem;">Scope</span>
            <select name="scope" style="width:100%;">
                <option value="all" selected>All (quotes + historical bars)</option>
                <option value="quotes">Quotes only (intraday snapshot)</option>
                <option value="history">Historical daily bars only</option>
            </select>
        </label>
        <button type="submit" class="btn btn-primary" style="align-self:flex-start;">
            <i class="bi bi-arrow-clockwise"></i> Run refresh
        </button>
        <small class="muted">
            Quotes covers every symbol in any holding, watchlist, or transaction.
            Historical fills in missing daily bars from each symbol's earliest
            purchase date through today.
        </small>
    </form>
</div>

@if (portfolios.Count > 0)
{
    <div class="card" style="padding:1rem;max-width:960px;margin-top:1rem;">
        <strong>Updated portfolio values</strong>
        <p class="muted" style="margin:.25rem 0 .75rem;">
            Market value reflects the freshly-pulled quotes (latest <code>PriceQuote</code>
            row per symbol) multiplied by current holdings, computed on the fly.
            Nothing is written to <code>PortfolioSnapshots</code>; the periodic
            <code>SnapshotJob</code> remains the single source of truth for stored snapshots.
        </p>
        <table class="table">
            <thead>
                <tr>
                    <th>Portfolio</th>
                    <th style="text-align:right;">Market value</th>
                    <th style="text-align:right;">Cost basis</th>
                    <th style="text-align:right;">Unrealized P/L</th>
                    <th style="text-align:right;">Cash</th>
                    <th style="text-align:right;">Total equity</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in portfolios)
                {
                    <tr>
                        <td><a href="/Portfolios/Detail/@p.PortfolioId">@p.Name</a></td>
                        <td style="text-align:right;">@p.MarketValue.Money(p.Currency)</td>
                        <td style="text-align:right;">@p.CostBasis.Money(p.Currency)</td>
                        <td style="text-align:right;@(p.UnrealizedPnL >= 0 ? "color:var(--pos,#1a7f37);" : "color:var(--neg,#cf222e);")">@p.UnrealizedPnL.Money(p.Currency)</td>
                        <td style="text-align:right;">@p.CashBalance.Money(p.Currency)</td>
                        <td style="text-align:right;font-weight:600;">@p.TotalEquity.Money(p.Currency)</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@if (coverage.Count > 0)
{
    <div class="card" style="padding:1rem;max-width:960px;margin-top:1rem;">
        <strong>Historical closing-price coverage</strong>
        <p class="muted" style="margin:.25rem 0 .75rem;">
            One row per symbol that has at least one transaction. <em>Rows</em> is the
            count of daily-close entries stored in <code>HistoricalPrices</code> between
            the first transaction date and today (weekends &amp; market holidays excluded).
        </p>
        <table class="table">
            <thead>
                <tr>
                    <th>Symbol</th>
                    <th style="text-align:right;">Rows stored</th>
                    <th>First transaction</th>
                    <th>Earliest close</th>
                    <th>Latest close</th>
                    <th>Up to date?</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var c in coverage)
                {
                    var fresh = c.MaxDate.HasValue && c.MaxDate.Value >= today.AddDays(-3);
                    var startOk = c.MinDate.HasValue && c.FirstTransaction.HasValue && c.MinDate.Value <= c.FirstTransaction.Value.AddDays(3);
                    <tr>
                        <td><strong>@c.Symbol</strong></td>
                        <td style="text-align:right;">@c.Rows</td>
                        <td>@(c.FirstTransaction?.ToString("yyyy-MM-dd") ?? "-")</td>
                        <td>@(c.MinDate?.ToString("yyyy-MM-dd") ?? "none")</td>
                        <td>@(c.MaxDate?.ToString("yyyy-MM-dd") ?? "none")</td>
                        <td>
                            @if (c.Rows == 0)
                            {
                                <span style="color:var(--neg,#cf222e);">No data</span>
                            }
                            else if (fresh && startOk)
                            {
                                <span style="color:var(--pos,#1a7f37);">OK</span>
                            }
                            else
                            {
                                <span style="color:var(--neg,#cf222e);">Gap</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@if (!string.IsNullOrWhiteSpace(payload))
{
    <details class="card" style="padding:1rem;max-width:960px;margin-top:1rem;">
        <summary><strong>Raw refresh result</strong></summary>
        <pre style="margin:.5rem 0 0;white-space:pre-wrap;word-break:break-word;">@payload</pre>
    </details>
}
