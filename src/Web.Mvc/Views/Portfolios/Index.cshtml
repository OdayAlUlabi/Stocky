@model List<PortfolioDto>
@{ ViewData["Title"] = "Portfolios"; }

<header style="display:flex;justify-content:space-between;align-items:baseline;">
    <h2>Portfolios</h2>
    <a href="/Portfolios/Create" role="button">+ New</a>
</header>

<table>
    <thead><tr><th>Name</th><th>Currency</th><th>Cost basis</th><th style="text-align:right;">Cash</th><th>Created</th><th></th></tr></thead>
    <tbody>
        @foreach (var p in Model)
        {
            <tr>
                <td><a href="/Portfolios/Detail/@p.Id">@p.Name</a></td>
                <td>@p.BaseCurrency</td>
                <td>@p.CostBasisMethod</td>
                <td style="text-align:right;">@p.CashBalance.Money(p.BaseCurrency)</td>
                <td>@p.CreatedAt.ToString("yyyy-MM-dd")</td>
                <td>
                    <a href="/Portfolios/Edit/@p.Id">Edit</a> ·
                    <form method="post" action="/Portfolios/Delete/@p.Id" style="display:inline;" onsubmit="return confirm('Delete @p.Name?');">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="secondary outline" style="padding:.1rem .4rem;">Delete</button>
                    </form>
                </td>
            </tr>
        }
        @if (Model.Count == 0)
        {
            <tr><td colspan="6"><em>No portfolios yet. <a href="/Portfolios/Create">Create one</a>.</em></td></tr>
        }
    </tbody>
</table>
