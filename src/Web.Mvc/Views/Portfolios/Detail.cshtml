@model List<HoldingDto>
@{
    var p = ViewBag.Portfolio as PortfolioDto;
    var perf = ViewBag.Performance as PortfolioPerformanceDto;
    ViewData["Title"] = p?.Name ?? "Portfolio";
}

<header style="display:flex;justify-content:space-between;align-items:baseline;flex-wrap:wrap;gap:.5rem;">
    <h2>@p?.Name</h2>
    <nav>
        <a href="/Portfolios/Edit/@p?.Id">Edit</a> ·
        <a href="/Portfolios/@p?.Id/Holdings">Holdings</a> ·
        <a href="/Portfolios/@p?.Id/Performance">Performance</a> ·
        <a href="/Portfolios/@p?.Id/History">History</a> ·
        <a href="/Portfolios/@p?.Id/Allocation">Allocation</a> ·
        <a href="/Portfolios/@p?.Id/Analytics">Analytics</a> ·
        <a href="/Portfolios/@p?.Id/Risk">Risk</a> ·
        <a href="/Portfolios/@p?.Id/VarSuite">VaR Suite</a> ·
        <a href="/Portfolios/@p?.Id/StressTest">Stress</a> ·
        <a href="/Portfolios/@p?.Id/Liquidity">Liquidity</a> ·
        <a href="/Portfolios/@p?.Id/Concentration">Concentration</a> ·
        <a href="/Portfolios/@p?.Id/Rebalance">Rebalance</a> ·
        <a href="/Portfolios/@p?.Id/CapitalGains">Capital Gains</a> ·
        <a href="/Portfolios/@p?.Id/Reports">Reports</a> ·
        <a href="/Portfolios/@p?.Id/Transactions">Transactions</a> ·
        <a href="/Portfolios/@p?.Id/Cash">Cash</a>
    </nav>
</header>

@if (perf is not null)
{
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:.5rem;">
        <article><small>Market value</small><h4>@perf.MarketValue.Money(perf.Currency)</h4></article>
        <article><small>Cost basis</small><h4>@perf.CostBasis.Money(perf.Currency)</h4></article>
        <article><small>Unrealized P&amp;L</small><h4 class="@perf.UnrealizedPnL.SignClass()">@perf.UnrealizedPnL.Money(perf.Currency) (@perf.UnrealizedPnLPercent.Pct())</h4></article>
        <article><small>Cash</small><h4>@perf.CashBalance.Money(perf.Currency)</h4></article>
    </div>
}

<h3>Holdings</h3>
<table>
    <thead><tr><th>Symbol</th><th style="text-align:right;">Qty</th><th style="text-align:right;">Avg cost</th><th style="text-align:right;">Last</th><th style="text-align:right;">Value</th><th>Strategy</th></tr></thead>
    <tbody>
        @foreach (var h in Model)
        {
            <tr>
                <td><a href="/Portfolios/@p?.Id/Positions/@h.Symbol">@h.Symbol</a></td>
                <td style="text-align:right;">@h.Quantity.Num(4)</td>
                <td style="text-align:right;">@h.AverageCost.Money(p?.BaseCurrency ?? "USD")</td>
                <td style="text-align:right;">@(h.LatestPrice?.Money(p?.BaseCurrency ?? "USD") ?? "—")</td>
                <td style="text-align:right;">@(h.MarketValue?.Money(p?.BaseCurrency ?? "USD") ?? "—")</td>
                <td>
                    <select class="strategy-select"
                            data-portfolio-id="@p?.Id"
                            data-symbol="@h.Symbol"
                            title="Position strategy for @h.Symbol">
                        @foreach (var opt in new[] { "General", "LongTerm", "Hodl", "MomentumPlays" })
                        {
                            <option value="@opt" selected="@(h.Strategy == opt ? "selected" : null)">@opt</option>
                        }
                    </select>
                </td>
            </tr>
        }
        @if (Model.Count == 0) { <tr><td colspan="6"><em>No holdings.</em></td></tr> }
    </tbody>
</table>

<script>
(function () {
    var csrfToken = document.querySelector('meta[name="x-csrf-token"]')?.getAttribute('content') || '';
    document.querySelectorAll('.strategy-select').forEach(function (sel) {
        sel.addEventListener('change', function () {
            var portfolioId = sel.dataset.portfolioId;
            var symbol = sel.dataset.symbol;
            var strategy = sel.value;
            fetch('/Portfolios/' + portfolioId + '/Holdings/' + symbol + '/Strategy', {
                method: 'PATCH',
                headers: {
                    'Content-Type': 'application/json',
                    'X-Requested-With': 'XMLHttpRequest',
                    'X-CSRF-TOKEN': csrfToken
                },
                body: JSON.stringify({ strategy: strategy })
            }).then(function (r) {
                if (!r.ok) {
                    alert('Failed to save strategy for ' + symbol);
                    location.reload();
                }
            });
        });
    });
})();
</script>
