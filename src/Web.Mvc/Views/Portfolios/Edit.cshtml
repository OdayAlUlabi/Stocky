@model UpdatePortfolioRequest
@{
    ViewData["Title"] = "Edit portfolio";
    var id = (Guid)ViewBag.Id;
}

<div class="page-header"><h2><i class="bi bi-briefcase"></i> Edit portfolio</h2></div>
<form method="post" action="/Portfolios/Edit/@id" style="max-width:520px;">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="All" class="flash error"></div>
    <label>Name <input name="Name" value="@Model.Name" required maxlength="120" /><span asp-validation-for="Name" class="text-danger"></span></label>
    <label>Base currency <input name="BaseCurrency" value="@Model.BaseCurrency" required maxlength="8" /></label>
    <label>Cost basis
        <select name="CostBasisMethod">
            <option value="FIFO" selected="@(Model.CostBasisMethod == "FIFO")">FIFO</option>
            <option value="LIFO" selected="@(Model.CostBasisMethod == "LIFO")">LIFO</option>
            <option value="Average" selected="@(Model.CostBasisMethod == "Average")">Average</option>
        </select>
    </label>
    <button type="submit">Save</button>
    <a href="/Portfolios/Detail/@id" class="btn btn-ghost">Cancel</a>
</form>
