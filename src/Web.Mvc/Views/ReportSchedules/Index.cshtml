@model List<ReportScheduleDto>
@{ ViewData["Title"] = "Report schedules"; }
<div class="page-header"><h2><i class="bi bi-file-earmark-text"></i> Scheduled reports</h2></div>

<h3>Create schedule</h3>
<form method="post" action="/ReportSchedules/Create" style="max-width:680px;">
    @Html.AntiForgeryToken()
    <div class="grid">
        <label>Portfolio ID <input name="portfolioId" required /></label>
        <label>Type
            <select name="type">
                @foreach (var t in new[] { "Performance","Holdings","Transactions","CapitalGains","Tax" })
                {
                    <option value="@t">@t</option>
                }
            </select>
        </label>
    </div>
    <div class="grid">
        <label>Format
            <select name="format">
                @foreach (var f in new[] { "Pdf","Csv","Xlsx","Json" })
                {
                    <option value="@f">@f</option>
                }
            </select>
        </label>
        <label>Cadence
            <select name="cadence">
                @foreach (var c in new[] { "Daily","Weekly","Monthly","Quarterly" })
                {
                    <option value="@c">@c</option>
                }
            </select>
        </label>
    </div>
    <div class="grid">
        <label>Email (optional) <input name="email" type="email" /></label>
        <label><input type="checkbox" name="enabled" value="true" checked /> Enabled</label>
    </div>
    <button type="submit">Create schedule</button>
</form>

<h3>Existing schedules</h3>
<table>
    <thead><tr><th>Type</th><th>Format</th><th>Cadence</th><th>Email</th><th>Enabled</th><th>Next run</th><th>Last run</th><th></th></tr></thead>
    <tbody>
        @foreach (var s in Model)
        {
            <tr>
                <td>@s.Type</td>
                <td>@s.Format</td>
                <td>@s.Cadence</td>
                <td>@s.Email</td>
                <td>@(s.Enabled ? "Yes" : "No")</td>
                <td>@s.NextRunUtc.ToString("yyyy-MM-dd HH:mm")</td>
                <td>@(s.LastRunUtc?.ToString("yyyy-MM-dd HH:mm") ?? "—")</td>
                <td>
                    <form method="post" action="/ReportSchedules/Run" style="display:inline;">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@s.Id" />
                        <button type="submit" class="btn btn-ghost btn-sm">Run now</button>
                    </form>
                    <form method="post" action="/ReportSchedules/Delete" style="display:inline;" onsubmit="return confirm('Delete?');">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@s.Id" />
                        <button type="submit" class="btn btn-ghost btn-sm">×</button>
                    </form>
                </td>
            </tr>
        }
        @if (Model.Count == 0) { <tr><td colspan="8"><em>No schedules.</em></td></tr> }
    </tbody>
</table>
