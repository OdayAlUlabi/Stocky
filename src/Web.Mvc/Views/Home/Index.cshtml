@model DashboardDto
@{
    ViewData["Title"] = "Dashboard";
    var portfolios = ViewBag.Portfolios as List<PortfolioDto> ?? new();
    var selected = ViewBag.SelectedPortfolioId as Guid?;
}

<div class="page-header">
    <h2><i class="bi bi-speedometer2"></i> Dashboard</h2>
    <div class="actions">
        @if (portfolios.Count > 1)
        {
            <form method="get" action="/" style="margin:0;display:flex;gap:.5rem;align-items:center;">
                <label style="margin:0;">Portfolio</label>
                <select name="portfolioId" onchange="this.form.submit()">
                    <option value="">All portfolios</option>
                    @foreach (var p in portfolios)
                    {
                        <option value="@p.Id" selected="@(selected == p.Id)">@p.Name</option>
                    }
                </select>
            </form>
        }
        <button id="btnRefreshAll" class="btn btn-ghost btn-sm" onclick="dashRefreshAll()" title="Refresh quotes &amp; history">
            <i class="bi bi-arrow-clockwise" id="refreshIcon"></i> Refresh
        </button>
        <a class="btn btn-ghost btn-sm" href="/Transactions"><i class="bi bi-arrow-left-right"></i> Transactions</a>
        <a class="btn btn-primary btn-sm" href="/Portfolios"><i class="bi bi-briefcase"></i> Portfolios</a>
    </div>
</div>
<form id="frmRefreshAll" method="post" action="/Admin/DataRefresh" style="display:none;">
    @Html.AntiForgeryToken()
    <input type="hidden" name="scope" value="all" />
</form>

@if (Model is null)
{
    <article>
        <p class="text-muted" style="margin:0;"><i class="bi bi-info-circle"></i> No dashboard data yet. Create a portfolio to get started.</p>
    </article>
    return;
}

@{
    var dayUp = Model.DayPnL >= 0;
    var totUp = Model.TotalReturn >= 0;
}

<div class="kpi-grid">
    <div class="kpi">
        <div class="label"><i class="bi bi-wallet2"></i> Total value</div>
        <div class="value">@Model.TotalValue.Money(Model.Currency)</div>
        <div class="delta text-muted">As of @Model.AsOf.ToLocalTime().ToString("MMM d · HH:mm")</div>
    </div>
    <div class="kpi">
        <div class="label"><i class="bi bi-activity"></i> Day P&amp;L</div>
        <div class="value @Model.DayPnL.SignClass()">@Model.DayPnL.Money(Model.Currency)</div>
        <div class="delta">
            <span class="@(dayUp ? "badge-up" : "badge-down")">
                <i class="bi @(dayUp ? "bi-caret-up-fill" : "bi-caret-down-fill")"></i>
                @Model.DayPnLPercent.Pct()
            </span>
        </div>
    </div>
    <div class="kpi">
        <div class="label"><i class="bi bi-graph-up"></i> Total return</div>
        <div class="value @Model.TotalReturn.SignClass()">@Model.TotalReturn.Money(Model.Currency)</div>
        <div class="delta">
            <span class="@(totUp ? "badge-up" : "badge-down")">
                <i class="bi @(totUp ? "bi-caret-up-fill" : "bi-caret-down-fill")"></i>
                @Model.TotalReturnPercent.Pct()
            </span>
        </div>
    </div>
    <div class="kpi">
        <div class="label"><i class="bi bi-cash-stack"></i> Cash</div>
        <div class="value">@Model.CashBalance.Money(Model.Currency)</div>
        <div class="delta text-muted">Equity @Model.TotalEquity.Money(Model.Currency)</div>
    </div>
</div>

@{
    var strategyGroups = ViewBag.StrategyGroups as Dictionary<string, List<StrategyHoldingDto>>;
    var strategyTotalValue = strategyGroups?.Values.SelectMany(x => x).Sum(h => h.MarketValue ?? 0m) ?? 0m;
}
@if (strategyGroups is { Count: > 0 })
{
    <article>
        <header>
            <span><i class="bi bi-flag"></i> Position strategy</span>
            <a class="btn btn-ghost btn-sm" href="/Strategy/Breakdown">View breakdown</a>
        </header>
        <table>
            <thead>
                <tr>
                    <th>Strategy</th>
                    <th style="text-align:right;">Holdings</th>
                    <th style="text-align:right;">Market value</th>
                    <th style="text-align:right;">%</th>
                    <th>Symbols</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var (strategy, items) in strategyGroups)
                {
                    var groupValue = items.Sum(h => h.MarketValue ?? 0m);
                    var pct = strategyTotalValue > 0 ? Math.Round(groupValue / strategyTotalValue * 100m, 1) : 0m;
                    var icon = strategy switch { "Hodl" => "bi-lock", "LongTerm" => "bi-hourglass-split", _ => "bi-grid" };
                    <tr>
                        <td><i class="bi @icon"></i> @strategy</td>
                        <td style="text-align:right;" class="text-muted">@items.Count</td>
                        <td style="text-align:right;">@groupValue.Money(Model.Currency)</td>
                        <td style="text-align:right;" class="text-muted">@pct%</td>
                        <td>
                            @foreach (var h in items.Take(8))
                            {
                                <span class="badge">@h.Symbol</span>
                            }
                            @if (items.Count > 8)
                            {
                                <span class="text-muted" style="font-size:.8em;">+@(items.Count - 8) more</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </article>
}

<div class="grid-2">
    <article>
        <header>
            <span><i class="bi bi-pie-chart"></i> Asset allocation</span>
            <small class="text-muted">@Model.AssetClassAllocation.Count holdings</small>
        </header>
        <div style="display:grid;grid-template-columns:200px 1fr;gap:1rem;align-items:center;">
            <div class="chart-donut"><canvas id="assetChart" width="200" height="200"></canvas></div>
            <table>
                <tbody>
                    @foreach (var s in Model.AssetClassAllocation)
                    {
                        <tr>
                            <td><span class="dot" data-label="@s.Label"></span> @s.Label</td>
                            <td style="text-align:right;">@s.Value.Money(Model.Currency)</td>
                            <td style="text-align:right;" class="text-muted">@s.Percent.Pct()</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </article>

    <article>
        <header>
            <span><i class="bi bi-graph-up-arrow"></i> Last 10 days changes</span>
            <small class="text-muted">daily portfolio value change</small>
        </header>
        <div class="chart-box-sm"><canvas id="historyChart"></canvas></div>
    </article>
</div>

<div class="grid-2">
    <article>
        <header><span><i class="bi bi-arrow-up-right-circle text-green"></i> Top gainers</span><small class="text-muted">today's $ change</small></header>
        <table>
            <thead><tr><th>Symbol</th><th style="text-align:right;">Value</th><th style="text-align:right;">Day $</th><th style="text-align:right;">Day %</th></tr></thead>
            <tbody>
                @if (Model.TopGainers.Count == 0)
                {
                    <tr><td colspan="4" class="text-muted" style="text-align:center;padding:1rem;">No data</td></tr>
                }
                @foreach (var m in Model.TopGainers)
                {
                    <tr>
                        <td>
                            @if (Model.PortfolioId is Guid pgid)
                            {
                                <a href="/Portfolios/@pgid/Positions/@m.Symbol"><strong>@m.Symbol</strong></a>
                            }
                            else
                            {
                                <strong>@m.Symbol</strong>
                            }
                        </td>
                        <td style="text-align:right;"><span data-price-symbol="@m.Symbol" data-price-currency="@Model.Currency">@m.MarketValue.Money(Model.Currency)</span></td>
                        <td style="text-align:right;" class="@m.DayChange.SignClass()">@m.DayChange.Money(Model.Currency)</td>
                        <td style="text-align:right;"><span class="badge-up"><i class="bi bi-caret-up-fill"></i><span data-price-symbol="@m.Symbol" data-price-kind="pct">@m.DayChangePercent.Pct()</span></span></td>
                    </tr>
                }
            </tbody>
        </table>
    </article>
    <article>
        <header><span><i class="bi bi-arrow-down-right-circle text-red"></i> Top losers</span><small class="text-muted">today's $ change</small></header>
        <table>
            <thead><tr><th>Symbol</th><th style="text-align:right;">Value</th><th style="text-align:right;">Day $</th><th style="text-align:right;">Day %</th></tr></thead>
            <tbody>
                @if (Model.TopLosers.Count == 0)
                {
                    <tr><td colspan="4" class="text-muted" style="text-align:center;padding:1rem;">No data</td></tr>
                }
                @foreach (var m in Model.TopLosers)
                {
                    <tr>
                        <td>
                            @if (Model.PortfolioId is Guid plid)
                            {
                                <a href="/Portfolios/@plid/Positions/@m.Symbol"><strong>@m.Symbol</strong></a>
                            }
                            else
                            {
                                <strong>@m.Symbol</strong>
                            }
                        </td>
                        <td style="text-align:right;"><span data-price-symbol="@m.Symbol" data-price-currency="@Model.Currency">@m.MarketValue.Money(Model.Currency)</span></td>
                        <td style="text-align:right;" class="@m.DayChange.SignClass()">@m.DayChange.Money(Model.Currency)</td>
                        <td style="text-align:right;"><span class="badge-down"><i class="bi bi-caret-down-fill"></i><span data-price-symbol="@m.Symbol" data-price-kind="pct">@m.DayChangePercent.Pct()</span></span></td>
                    </tr>
                }
            </tbody>
        </table>
    </article>
</div>

@if (Model.ValueHistory is { Count: > 0 })
{
    <article>
        <header>
            <span><i class="bi bi-graph-up-arrow"></i> Portfolio value — Cash vs Stocks</span>
            <small class="text-muted">@Model.ValueHistory.Count points</small>
        </header>
        <div class="chart-box"><canvas id="valueChart"></canvas></div>
    </article>
}

@section Scripts {
    <partial name="_ChartScripts" />
    <script>
        (function () {
            const palette = ['#5b9dff','#16c784','#f0b90b','#ea3943','#a78bfa','#22d3ee','#fb7185','#84cc16','#f97316','#06b6d4'];
            const css = getComputedStyle(document.documentElement);
            const txtMuted = css.getPropertyValue('--text-muted').trim() || '#97a3b8';
            const border = css.getPropertyValue('--border').trim() || '#243152';

            // Tint legend dots inside the asset table
            document.querySelectorAll('.dot').forEach((el, i) => {
                el.style.display = 'inline-block';
                el.style.width = '10px';
                el.style.height = '10px';
                el.style.borderRadius = '50%';
                el.style.marginRight = '.35rem';
                el.style.background = palette[i % palette.length];
                el.style.verticalAlign = 'middle';
            });

            const assetCanvas = document.getElementById('assetChart');
            if (assetCanvas && window.Chart) {
                const labels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.AssetClassAllocation.Select(a => a.Label)));
                const data = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.AssetClassAllocation.Select(a => a.Value)));
                new Chart(assetCanvas, {
                    type: 'doughnut',
                    data: { labels, datasets: [{ data, backgroundColor: palette, borderColor: '#131c2e', borderWidth: 2 }] },
                    options: {
                        responsive: false,
                        plugins: { legend: { display: false } },
                        cutout: '65%'
                    }
                });
            }

            const valueCanvas = document.getElementById('valueChart');
            if (valueCanvas && window.Chart) {
                const labels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ValueHistory.Select(p => p.Date.ToString("yyyy-MM-dd"))));
                const cash = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ValueHistory.Select(p => p.Cash)));
                const stocks = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ValueHistory.Select(p => p.MarketValue)));
                const total = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ValueHistory.Select(p => p.Value)));
                new Chart(valueCanvas, {
                    type: 'line',
                    data: {
                        labels,
                        datasets: [
                            {
                                label: 'Stocks value',
                                data: stocks,
                                borderColor: '#5b9dff',
                                backgroundColor: 'rgba(91,157,255,.15)',
                                fill: false,
                                tension: .25,
                                pointRadius: 0,
                                borderWidth: 1.75,
                                order: 2
                            },
                            {
                                label: 'Cash',
                                data: cash,
                                borderColor: '#16c784',
                                backgroundColor: 'rgba(22,199,132,.15)',
                                fill: false,
                                tension: .25,
                                pointRadius: 0,
                                borderWidth: 1.75,
                                order: 3
                            },
                            {
                                label: 'Total',
                                data: total,
                                borderColor: '#f0b90b',
                                backgroundColor: 'transparent',
                                fill: false,
                                tension: .25,
                                pointRadius: 0,
                                borderWidth: 2,
                                order: 1
                            }
                        ]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        interaction: { mode: 'index', intersect: false },
                        plugins: {
                            legend: { display: true, labels: { color: txtMuted } },
                            tooltip: {
                                callbacks: {
                                    footer: function (items) {
                                        if (!items || !items.length) return '';
                                        var i = items[0].dataIndex;
                                        return 'Total: ' + (total[i] != null ? Number(total[i]).toLocaleString() : '');
                                    }
                                }
                            }
                        },
                        scales: {
                            x: { ticks: { color: txtMuted, maxTicksLimit: 8 }, grid: { color: border } },
                            y: { ticks: { color: txtMuted }, grid: { color: border } }
                        }
                    }
                });
            }

            @{
                var last11 = Model.ValueHistory.TakeLast(11).ToList();
                var histDates = last11.Skip(1).Select(p => p.Date.ToString("MMM d")).ToList();
                var histChanges = Enumerable.Range(1, last11.Count - 1)
                    .Select(i => last11[i].Value - last11[i - 1].Value).ToList();
            }
            const historyCanvas = document.getElementById('historyChart');
            if (historyCanvas && window.Chart && @(histChanges.Count > 0 ? "true" : "false")) {
                const histLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(histDates));
                const histDeltas = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(histChanges));
                const histColors = histDeltas.map(v => v >= 0 ? 'rgba(22,199,132,.85)' : 'rgba(234,57,67,.85)');
                new Chart(historyCanvas, {
                    type: 'bar',
                    data: {
                        labels: histLabels,
                        datasets: [{ label: 'Daily change', data: histDeltas, backgroundColor: histColors, borderRadius: 3, borderWidth: 0 }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: { display: false },
                            tooltip: { callbacks: { label: ctx => (ctx.raw >= 0 ? '+' : '') + ctx.raw.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 }) } }
                        },
                        scales: {
                            x: { ticks: { color: txtMuted }, grid: { display: false } },
                            y: { ticks: { color: txtMuted }, grid: { color: border } }
                        }
                    }
                });
            }
        })();
    </script>
    <script>
        function dashRefreshAll() {
            var btn  = document.getElementById('btnRefreshAll');
            var icon = document.getElementById('refreshIcon');
            if (btn.disabled) return;
            btn.disabled = true;
            icon.className = 'bi bi-arrow-clockwise spin';
            btn.title = 'Refreshing…';

            var frm = document.getElementById('frmRefreshAll');
            var body = new URLSearchParams(new FormData(frm)).toString();
            fetch(frm.action, {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: body
            }).then(function(r) {
                if (r.ok || r.redirected) {
                    icon.className = 'bi bi-check-circle-fill';
                    btn.style.color = 'var(--green)';
                    setTimeout(function() { window.location.reload(); }, 800);
                } else {
                    icon.className = 'bi bi-exclamation-triangle-fill';
                    btn.style.color = 'var(--red)';
                    btn.title = 'Refresh failed (' + r.status + ')';
                    btn.disabled = false;
                }
            }).catch(function() {
                icon.className = 'bi bi-exclamation-triangle-fill';
                btn.style.color = 'var(--red)';
                btn.title = 'Refresh failed';
                btn.disabled = false;
            });
        }
    </script>
}
