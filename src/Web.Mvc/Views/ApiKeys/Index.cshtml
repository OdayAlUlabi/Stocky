@model List<ApiKeyDto>
@{
    ViewData["Title"] = "API keys";
    var newName = TempData["NewKeyName"] as string;
    var newPlain = TempData["NewKeyPlaintext"] as string;
}
<div class="page-header"><h2><i class="bi bi-key"></i> API keys</h2></div>

@if (!string.IsNullOrEmpty(newPlain))
{
    <article style="border-color:var(--amber);">
        <header><span><i class="bi bi-check-circle text-amber"></i> New key created: <strong>@newName</strong></span></header>
        <p class="text-muted" style="margin:.25rem 0 .75rem;">Copy this key now — it will <strong>not</strong> be shown again.</p>
        <pre style="white-space:pre-wrap;word-break:break-all;"><code>@newPlain</code></pre>
    </article>
}

<article>
    <header><span><i class="bi bi-plus-circle"></i> Create new key</span></header>
    <form method="post" action="/ApiKeys/Create" style="max-width:560px;">
        @Html.AntiForgeryToken()
        <div class="grid" style="margin-bottom:.75rem;">
            <label>Name <input name="name" required /></label>
            <label>Scopes (optional, csv) <input name="scopes" placeholder="read,write" /></label>
        </div>
        <label>Expires at (optional) <input name="expiresAt" type="datetime-local" /></label>
        <div style="margin-top:.75rem;">
            <button type="submit" class="btn btn-primary"><i class="bi bi-key"></i> Create key</button>
        </div>
    </form>
</article>

<article>
    <header><span><i class="bi bi-list-ul"></i> Existing keys</span></header>
    <table>
        <thead>
            <tr>
                <th>Name</th><th>Prefix</th><th>Scopes</th>
                <th>Created</th><th>Expires</th><th>Last used</th>
                <th>Active</th><th style="text-align:right;"></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var k in Model)
            {
                <tr>
                    <td><strong>@k.Name</strong></td>
                    <td><code>@k.Prefix…</code></td>
                    <td><span class="pill">@(k.Scopes ?? "all")</span></td>
                    <td class="text-muted">@k.CreatedAt.ToString("MMM d, yyyy")</td>
                    <td class="text-muted">@(k.ExpiresAt?.ToString("MMM d, yyyy") ?? "—")</td>
                    <td class="text-muted">@(k.LastUsedAt?.ToString("MMM d, yyyy HH:mm") ?? "—")</td>
                    <td>
                        @if (k.IsActive)
                        {
                            <span class="status-badge s-active"><i class="bi bi-circle-fill" style="font-size:.5rem;"></i> Active</span>
                        }
                        else
                        {
                            <span class="status-badge s-disabled">Revoked</span>
                        }
                    </td>
                    <td style="text-align:right;">
                        @if (k.IsActive)
                        {
                            <form method="post" action="/ApiKeys/Revoke" style="display:inline;" onsubmit="return confirm('Revoke @k.Name?');">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@k.Id" />
                                <button type="submit" class="btn btn-danger btn-sm"><i class="bi bi-x-lg"></i> Revoke</button>
                            </form>
                        }
                    </td>
                </tr>
            }
            @if (Model.Count == 0)
            {
                <tr><td colspan="8">
                    <div class="empty-state">
                        <i class="bi bi-key empty-icon"></i>
                        <p>No API keys yet.</p>
                    </div>
                </td></tr>
            }
        </tbody>
    </table>
</article>
