@model List<InstrumentDto>
@{ ViewData["Title"] = "Instrument search"; }
<div class="page-header"><h2><i class="bi bi-funnel"></i> Instrument search</h2></div>
<form method="get" action="/Screener/Search" style="display:flex;gap:.5rem;align-items:end;">
    <label style="flex:1;">Query <input name="q" value="@(ViewBag.Query as string)" required /></label>
    <button type="submit">Search</button>
</form>
<table>
    <thead><tr><th>Symbol</th><th>Name</th><th>Exchange</th><th>Currency</th><th>Class</th></tr></thead>
    <tbody>
        @foreach (var r in Model)
        {
            <tr><td>@r.Symbol</td><td>@r.Name</td><td>@r.Exchange</td><td>@r.Currency</td><td>@r.AssetClass</td></tr>
        }
        @if (Model.Count == 0) { <tr><td colspan="5"><em>No matches.</em></td></tr> }
    </tbody>
</table>
