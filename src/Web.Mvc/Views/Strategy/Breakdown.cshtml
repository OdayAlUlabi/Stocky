@using Stocky.Web.Mvc.ViewModels
@model StrategyBreakdownViewModel
@{
    ViewData["Title"] = "Strategy Breakdown";
    var selectedName = Model.SelectedPortfolioId.HasValue
        ? Model.Portfolios.FirstOrDefault(p => p.Id == Model.SelectedPortfolioId)?.Name ?? "Selected"
        : "All portfolios";
}

<header style="display:flex;justify-content:space-between;align-items:baseline;flex-wrap:wrap;gap:.5rem;">
    <h2>Strategy Breakdown</h2>
    <small>Total market value: <strong>@Model.TotalMarketValue.ToString("N2")</strong></small>
</header>

@* Portfolio filter *@
<form method="get" style="display:flex;align-items:center;gap:.75rem;margin-bottom:1.5rem;flex-wrap:wrap;">
    <label for="portfolioId" style="font-weight:500;white-space:nowrap;">Filter by portfolio:</label>
    <select id="portfolioId" name="portfolioId" onchange="this.form.submit()" style="min-width:16rem;">
        <option value="">All portfolios</option>
        @foreach (var p in Model.Portfolios)
        {
            if (Model.SelectedPortfolioId == p.Id)
            {
                <option value="@p.Id" selected>@p.Name (@p.BaseCurrency)</option>
            }
            else
            {
                <option value="@p.Id">@p.Name (@p.BaseCurrency)</option>
            }
        }
    </select>
    @if (Model.SelectedPortfolioId.HasValue)
    {
        <a href="/Strategy/Breakdown" class="btn btn-ghost btn-sm">Clear filter</a>
    }
</form>

@if (!Model.Groups.Any())
{
    <p><em>No holdings found. Open a portfolio and assign strategies via the Holdings table.</em></p>
}
else
{
    @foreach (var group in Model.Groups)
    {
        var groupList   = group.ToList();
        var totalCost   = groupList.Sum(h => h.Quantity * h.AverageCost);
        var totalValue  = groupList.Sum(h => h.MarketValue ?? 0m);
        var totalPnl    = totalValue - totalCost;
        var totalPnlPct = totalCost > 0 ? Math.Round(totalPnl / totalCost * 100m, 2) : 0m;
        var groupPnlUp  = totalPnl >= 0;

        <section style="margin-bottom:2.5rem;">
            <h3 style="display:flex;align-items:baseline;gap:1rem;flex-wrap:wrap;">
                @group.Key
                <small style="font-weight:normal;font-size:.8em;">@groupList.Count position@(groupList.Count == 1 ? "" : "s")</small>
                <span class="@(groupPnlUp ? "text-green" : "text-red")" style="font-size:.85em;font-weight:600;">
                    <i class="bi @(groupPnlUp ? "bi-caret-up-fill" : "bi-caret-down-fill")" style="font-size:.75em;"></i>
                    @totalPnl.ToString("N2") (@totalPnlPct%)
                </span>
            </h3>
            <table style="font-size:.9em;">
                <thead>
                    <tr>
                        <th>Portfolio</th>
                        <th>Symbol</th>
                        <th style="text-align:right;">Qty</th>
                        <th style="text-align:right;">Avg cost</th>
                        <th style="text-align:right;">Last price</th>
                        <th style="text-align:right;">Cost basis</th>
                        <th style="text-align:right;">Market value</th>
                        <th style="text-align:right;">P&amp;L $</th>
                        <th style="text-align:right;">P&amp;L %</th>
                        <th style="text-align:center;" title="Take Profit 1">TP 1</th>
                        <th style="text-align:center;" title="Take Profit 2">TP 2</th>
                        <th style="text-align:center;" title="Take Profit 3">TP 3</th>
                        <th style="text-align:center;" title="Stop Loss">Stop Loss</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var h in groupList.OrderByDescending(x => (x.MarketValue ?? 0m) - x.Quantity * x.AverageCost))
                    {
                        var costBasis = h.Quantity * h.AverageCost;
                        var mv        = h.MarketValue ?? 0m;
                        var pnl       = mv - costBasis;
                        var pnlPct    = costBasis > 0 ? Math.Round(pnl / costBasis * 100m, 2) : 0m;
                        var pnlUp     = pnl >= 0;
                        var last      = h.LatestPrice;
                        // TP is "hit" (crossed) if last >= target; style struck-through
                        // StopLoss is "triggered" if last <= stoploss; style red
                        string TpClass(decimal? tp) =>
                            (last.HasValue && tp.HasValue && last.Value >= tp.Value) ? "tp-hit" : "tp-pending";
                        string SlClass() =>
                            (last.HasValue && h.StopLoss.HasValue && last.Value <= h.StopLoss.Value) ? "sl-triggered" : "sl-safe";
                        <tr data-portfolio-id="@h.PortfolioId" data-symbol="@h.Symbol">
                            <td class="text-muted" style="font-size:.9em;">@h.PortfolioName</td>
                            <td><strong>@h.Symbol</strong></td>
                            <td style="text-align:right;" class="text-muted">@h.Quantity.ToString("N4")</td>
                            <td style="text-align:right;" class="text-muted">@h.AverageCost.ToString("N2")</td>
                            <td style="text-align:right;" class="text-muted">@(h.LatestPrice.HasValue ? h.LatestPrice.Value.ToString("N2") : "—")</td>
                            <td style="text-align:right;" class="text-muted">@costBasis.ToString("N2")</td>
                            <td style="text-align:right;">@(h.MarketValue.HasValue ? mv.ToString("N2") : "—")</td>
                            <td style="text-align:right;" class="@(pnlUp ? "text-green" : "text-red")">
                                <i class="bi @(pnlUp ? "bi-caret-up-fill" : "bi-caret-down-fill")" style="font-size:.7em;"></i>
                                @pnl.ToString("N2")
                            </td>
                            <td style="text-align:right;" class="@(pnlUp ? "text-green" : "text-red")">@pnlPct%</td>
                            <td style="text-align:center;"><input type="number" class="target-input @TpClass(h.Target1)" data-field="target1" value="@(h.Target1.HasValue ? h.Target1.Value.ToString("F2") : "")" step="0.01" min="0" placeholder="—" /></td>
                            <td style="text-align:center;"><input type="number" class="target-input @TpClass(h.Target2)" data-field="target2" value="@(h.Target2.HasValue ? h.Target2.Value.ToString("F2") : "")" step="0.01" min="0" placeholder="—" /></td>
                            <td style="text-align:center;"><input type="number" class="target-input @TpClass(h.Target3)" data-field="target3" value="@(h.Target3.HasValue ? h.Target3.Value.ToString("F2") : "")" step="0.01" min="0" placeholder="—" /></td>
                            <td style="text-align:center;"><input type="number" class="target-input @SlClass()" data-field="stoploss" value="@(h.StopLoss.HasValue ? h.StopLoss.Value.ToString("F2") : "")" step="0.01" min="0" placeholder="—" /></td>
                        </tr>
                    }
                </tbody>
                <tfoot>
                    <tr style="font-weight:600;border-top:2px solid var(--border,#e0e0e0);">
                        <td colspan="5" style="text-align:right;">Group total</td>
                        <td style="text-align:right;">@totalCost.ToString("N2")</td>
                        <td style="text-align:right;">@totalValue.ToString("N2")</td>
                        <td style="text-align:right;" class="@(groupPnlUp ? "text-green" : "text-red")">
                            <i class="bi @(groupPnlUp ? "bi-caret-up-fill" : "bi-caret-down-fill")" style="font-size:.7em;"></i>
                            @totalPnl.ToString("N2")
                        </td>
                        <td style="text-align:right;" class="@(groupPnlUp ? "text-green" : "text-red")">@totalPnlPct%</td>
                        <td colspan="4"></td>
                    </tr>
                </tfoot>
            </table>
        </section>
    }
}

<style>
.target-input {
    width: 6rem;
    padding: 0.2rem 0.3rem;
    font-size: .85em;
    text-align: right;
    border: 1px solid var(--border, #d0d0d0);
    border-radius: 4px;
    background: transparent;
    color: inherit;
    transition: border-color .15s, background .15s;
}
.target-input:focus {
    outline: none;
    border-color: var(--accent, #0066cc);
    background: var(--surface-raised, #fff);
}
.target-input.tp-hit {
    text-decoration: line-through;
    opacity: .55;
    border-color: var(--green, #28a745);
    color: var(--green, #28a745);
}
.target-input.tp-pending {
    border-color: var(--border, #d0d0d0);
}
.target-input.sl-triggered {
    border-color: var(--red, #dc3545);
    color: var(--red, #dc3545);
    background: rgba(220,53,69,.07);
}
.target-input.sl-safe {
    border-color: var(--border, #d0d0d0);
}
.target-input.saving {
    opacity: .5;
}
@@keyframes flash-ok {
    0%   { background-color: rgba(40,167,69,.35); }
    100% { background-color: transparent; }
}
@@keyframes flash-err {
    0%   { background-color: rgba(220,53,69,.35); }
    100% { background-color: transparent; }
}
.target-input.flash-ok  { animation: flash-ok  .6s ease-out forwards; }
.target-input.flash-err { animation: flash-err .6s ease-out forwards; }
</style>

<script>
(function () {
    var csrfToken = document.querySelector('meta[name="x-csrf-token"]')?.getAttribute('content') || '';

    function getRowInputs(input) {
        var row = input.closest('tr');
        var inputs = row.querySelectorAll('.target-input');
        var map = {};
        inputs.forEach(function (i) { map[i.dataset.field] = i; });
        return map;
    }

    function saveRow(input) {
        var row = input.closest('tr');
        var portfolioId = row.dataset.portfolioId;
        var symbol = row.dataset.symbol;
        var fields = getRowInputs(input);

        function parseVal(inp) {
            var v = inp ? inp.value.trim() : '';
            return v === '' ? null : parseFloat(v);
        }

        var body = {
            target1:  parseVal(fields['target1']),
            target2:  parseVal(fields['target2']),
            target3:  parseVal(fields['target3']),
            stopLoss: parseVal(fields['stoploss'])
        };

        row.querySelectorAll('.target-input').forEach(function (i) { i.classList.add('saving'); });

        fetch('/Portfolios/' + portfolioId + '/Holdings/' + encodeURIComponent(symbol) + '/Targets', {
            method: 'PATCH',
            headers: {
                'Content-Type': 'application/json',
                'X-Requested-With': 'XMLHttpRequest',
                'X-CSRF-TOKEN': csrfToken
            },
            body: JSON.stringify(body)
        }).then(function (r) {
            row.querySelectorAll('.target-input').forEach(function (i) { i.classList.remove('saving'); });
            if (r.ok) {
                row.querySelectorAll('.target-input').forEach(function (i) {
                    i.classList.remove('flash-err');
                    void i.offsetWidth;
                    i.classList.add('flash-ok');
                    setTimeout(function () { i.classList.remove('flash-ok'); }, 700);
                });
            } else {
                row.querySelectorAll('.target-input').forEach(function (i) {
                    i.classList.remove('flash-ok');
                    void i.offsetWidth;
                    i.classList.add('flash-err');
                    setTimeout(function () { i.classList.remove('flash-err'); }, 700);
                });
            }
        }).catch(function () {
            row.querySelectorAll('.target-input').forEach(function (i) {
                i.classList.remove('saving');
                i.classList.add('flash-err');
                setTimeout(function () { i.classList.remove('flash-err'); }, 700);
            });
        });
    }

    document.querySelectorAll('.target-input').forEach(function (input) {
        var prev = input.value;
        input.addEventListener('focus', function () { prev = input.value; });
        input.addEventListener('blur', function () {
            if (input.value !== prev) { saveRow(input); }
        });
        input.addEventListener('keydown', function (e) {
            if (e.key === 'Enter') { input.blur(); }
            if (e.key === 'Escape') { input.value = prev; input.blur(); }
        });
    });
})();
</script>
